<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:GitFlick.ViewModels"
        xmlns:loc="using:GitFlick.Markup"
        xmlns:updates="using:GitFlick.Services.Updates"
        x:Class="GitFlick.Views.SettingsWindow"
        x:DataType="vm:SettingsViewModel"
        Title="{loc:Tr Settings_Title}"
        Icon="/Assets/gitflick.ico"
        Width="460" Height="600"
        MinWidth="380" MinHeight="360"
        WindowStartupLocation="CenterOwner">

    <Window.Styles>
        <!-- Accent swatch: a bare clickable circle. Clears the global secondary-button chrome
             (App.axaml paints every Button's ContentPresenter with the accent-subtle chip) so the
             only thing visible is the colour dot and, when selected, its ring. -->
        <Style Selector="Button.swatch /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        <Style Selector="Button.swatch:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        <Style Selector="Button.swatch:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
    </Window.Styles>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
    <StackPanel Margin="22" Spacing="18">
        <TextBlock x:Name="HeaderText" Text="{loc:Tr Settings_Header}" FontSize="18" FontWeight="SemiBold" />

        <StackPanel Spacing="6">
            <TextBlock x:Name="LanguageLabel" Text="{loc:Tr Settings_Language}" FontSize="10" Opacity="0.5" />
            <ComboBox HorizontalAlignment="Stretch" SelectedIndex="{Binding LanguageIndex, Mode=TwoWay}">
                <ComboBoxItem Content="English" />
                <ComboBoxItem Content="繁體中文" />
                <ComboBoxItem Content="简体中文" />
                <ComboBoxItem Content="日本語" />
            </ComboBox>
        </StackPanel>

        <StackPanel Spacing="6">
            <TextBlock x:Name="ThemeLabel" Text="{loc:Tr Settings_Theme}" FontSize="10" Opacity="0.5" />
            <ComboBox x:Name="ThemeCombo" HorizontalAlignment="Stretch"
                      SelectedIndex="{Binding ThemeVariantIndex, Mode=TwoWay}">
                <ComboBoxItem x:Name="ThemeSystemItem" Content="{loc:Tr Settings_Theme_System}" />
                <ComboBoxItem x:Name="ThemeLightItem" Content="{loc:Tr Settings_Theme_Light}" />
                <ComboBoxItem x:Name="ThemeDarkItem" Content="{loc:Tr Settings_Theme_Dark}" />
            </ComboBox>
        </StackPanel>

        <StackPanel Spacing="6">
            <TextBlock x:Name="AccentLabel" Text="{loc:Tr Settings_Accent}" FontSize="10" Opacity="0.5" />
            <ItemsControl x:Name="AccentList" ItemsSource="{Binding AccentSwatches}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="vm:AccentSwatch">
                        <Button Classes="swatch" Padding="0" Margin="3"
                                Command="{Binding $parent[ItemsControl].((vm:SettingsViewModel)DataContext).SelectAccentCommand}"
                                CommandParameter="{Binding Hex}"
                                ToolTip.Tip="{Binding Hex}">
                            <Panel Width="30" Height="30">
                                <Ellipse Width="30" Height="30" Fill="Transparent"
                                         Stroke="{DynamicResource SubtleForeground}" StrokeThickness="2"
                                         IsVisible="{Binding IsSelected}" />
                                <Ellipse Width="20" Height="20" Fill="{Binding Brush}"
                                         HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Panel>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>

        <StackPanel Spacing="6">
            <TextBlock Text="{loc:Tr Settings_Hotkey}" FontSize="10" Opacity="0.5" />
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <!-- Click to arm, then press a combo. The window's tunnelling KeyDown records it. -->
                <Button Grid.Column="0" x:Name="HotkeyCaptureButton"
                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                        FontFamily="Cascadia Mono,Consolas,monospace"
                        Content="{Binding HotkeyButtonText}"
                        IsEnabled="{Binding CanEditHotkey}"
                        Command="{Binding StartHotkeyCaptureCommand}"
                        LostFocus="OnHotkeyCaptureLostFocus" />
                <Button Grid.Column="1" Content="{loc:Tr Settings_Hotkey_Reset}"
                        IsEnabled="{Binding CanEditHotkey}"
                        Command="{Binding ResetHotkeyCommand}" />
            </Grid>
            <TextBlock Text="{loc:Tr Settings_Hotkey_Hint}" FontSize="11" Opacity="0.5" TextWrapping="Wrap" />
            <TextBlock Text="{Binding HotkeyError}" IsVisible="{Binding HasHotkeyError}"
                       FontSize="11" TextWrapping="Wrap" Foreground="{DynamicResource RedBrush}" />
        </StackPanel>

        <Border Height="1" Background="{DynamicResource SubtleForeground}" Opacity="0.15" Margin="0,2" />

        <StackPanel Spacing="10">
            <TextBlock Text="{loc:Tr Settings_Updates}" FontSize="10" Opacity="0.5" />

            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0" VerticalAlignment="Center" FontSize="13">
                    <Run Text="{loc:Tr Update_CurrentVersion}" Foreground="{DynamicResource SubtleForeground}" />
                    <Run Text="{Binding CurrentVersionText}" FontWeight="SemiBold" />
                </TextBlock>
                <Button Grid.Column="1" Content="{loc:Tr Update_CheckForUpdates}"
                        Command="{Binding CheckForUpdatesCommand}" IsEnabled="{Binding !IsLoadingReleases}" />
            </Grid>

            <TextBlock Text="{Binding UpdateStatus}" IsVisible="{Binding HasUpdateStatus}"
                       TextWrapping="Wrap" FontSize="12" Opacity="0.85" />

            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8" IsVisible="{Binding HasReleases}">
                <ComboBox Grid.Column="0" HorizontalAlignment="Stretch"
                          ItemsSource="{Binding AvailableReleases}"
                          SelectedItem="{Binding SelectedRelease, Mode=TwoWay}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="updates:ReleaseInfo">
                            <TextBlock Text="{Binding TagName}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <Button Grid.Column="1" Classes="primary" Content="{loc:Tr Update_InstallSelected}"
                        Command="{Binding InstallSelectedCommand}" />
            </Grid>

            <TextBlock Text="{Binding SelectedReleasePublished}" IsVisible="{Binding HasReleases}"
                       FontSize="10" Opacity="0.5" />

            <StackPanel Spacing="4" IsVisible="{Binding IsDownloading}">
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0" Text="{Binding DownloadStageText}" FontSize="11" Opacity="0.7" />
                    <TextBlock Grid.Column="1" Text="{Binding DownloadPercentText}" FontSize="11" Opacity="0.7" />
                </Grid>
                <ProgressBar Minimum="0" Maximum="100" Value="{Binding DownloadProgress}" />
                <Button Content="{loc:Tr Update_Cancel}" Command="{Binding CancelDownloadCommand}"
                        HorizontalAlignment="Right" />
            </StackPanel>

            <TextBlock Text="{Binding LastUpdateError}" IsVisible="{Binding HasUpdateError}"
                       TextWrapping="Wrap" FontSize="11" Foreground="#F85149" />

            <CheckBox Content="{loc:Tr Update_AutoCheck}" IsChecked="{Binding AutoCheckUpdates, Mode=TwoWay}" />
        </StackPanel>
    </StackPanel>
    </ScrollViewer>
</Window>
