<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:GitFlick.ViewModels"
        xmlns:models="using:GitFlick.Models"
        xmlns:services="using:GitFlick.Services"
        xmlns:views="using:GitFlick.Views"
        xmlns:conv="using:GitFlick.Converters"
        xmlns:loc="using:GitFlick.Markup"
        xmlns:sys="using:System"
        xmlns:edit="using:AvaloniaEdit"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1060" d:DesignHeight="660"
        x:Class="GitFlick.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Icon="/Assets/gitflick.ico"
        Title="GitFlick"
        Width="1060" Height="660"
        MinWidth="640" MinHeight="460"
        WindowStartupLocation="Manual"
        ShowInTaskbar="True">

    <Design.DataContext>
        <vm:MainViewModel />
    </Design.DataContext>

    <Window.Resources>
        <!-- One-line variant of the commit branch/HEAD card, for the bar above the diff: SHA, HEAD chip
             and branch all on a single row, so it costs one row of height instead of three. Applied
             explicitly via ContentTemplate (the stacked implicit template below still serves the
             graph-dot tooltip). A WrapPanel, not a StackPanel, so a long branch name wraps rather than
             overflowing; every element is a sibling that gates itself, hence ShowInHead/ShowNotInHead,
             which fold the "loaded yet?" check into the chips. -->
        <DataTemplate x:Key="BranchInfoLine" DataType="vm:CommitBranchInfo">
            <WrapPanel Orientation="Horizontal">
                <TextBlock FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0">
                    <Run Text="{loc:Tr History_Hover_CommitLabel}" Foreground="{DynamicResource SubtleForeground}" />
                    <Run Text="{Binding Sha}" FontFamily="Cascadia Mono,Consolas,monospace" FontWeight="SemiBold" />
                </TextBlock>

                <TextBlock Text="{loc:Tr History_Hover_Loading}" FontSize="11" Opacity="0.7"
                           VerticalAlignment="Center" IsVisible="{Binding !IsLoaded}" />

                <Border CornerRadius="3" Padding="6,1" Margin="0,0,8,0" BorderThickness="1"
                        VerticalAlignment="Center"
                        Background="#2C8F41" BorderBrush="#3FB950" IsVisible="{Binding ShowInHead}">
                    <TextBlock Text="{loc:Tr History_Hover_InHead}" FontSize="10" Foreground="White" />
                </Border>
                <Border CornerRadius="3" Padding="6,1" Margin="0,0,8,0" BorderThickness="1"
                        VerticalAlignment="Center"
                        Background="#4D555E" BorderBrush="#6A737D" IsVisible="{Binding ShowNotInHead}">
                    <TextBlock Text="{loc:Tr History_Hover_NotInHead}" FontSize="10" Foreground="White" />
                </Border>

                <!-- Same colours as the commit-row badges: local orange, remote purple, tag green.
                     Without the kind, "main" and "origin/main" are indistinguishable. -->
                <ItemsControl ItemsSource="{Binding Branches}" IsVisible="{Binding HasBranches}"
                              VerticalAlignment="Center">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="models:GitRef">
                            <Border Classes.tag="{Binding IsTag}" Classes.remote="{Binding IsRemoteBranch}"
                                    CornerRadius="3" Padding="5,1" Margin="0,0,3,0" MaxWidth="230">
                                <TextBlock Text="{Binding Name}" FontSize="10" Foreground="White"
                                           TextTrimming="CharacterEllipsis" />
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- "+N" for refs past the cap. Outside the ItemsControl so the badge styles, which key
                     off ItemsControl > ContentPresenter > Border, leave it neutral. -->
                <Border CornerRadius="3" Padding="5,1" Margin="0,0,8,0" BorderThickness="1"
                        VerticalAlignment="Center"
                        Background="#4D555E" BorderBrush="#6A737D" IsVisible="{Binding HasOverflow}">
                    <TextBlock Text="{Binding OverflowText}" FontSize="10" Foreground="White" />
                </Border>

                <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center"
                            IsVisible="{Binding HasNearest}">
                    <TextBlock Text="{loc:Tr History_Hover_OnBranch}" FontSize="10" Opacity="0.6"
                               VerticalAlignment="Center" IsVisible="{Binding !NearestIsMerge}" />
                    <TextBlock Text="{loc:Tr History_Hover_MergedFrom}" FontSize="10" Opacity="0.6"
                               VerticalAlignment="Center" IsVisible="{Binding NearestIsMerge}" />
                    <Border CornerRadius="3" Padding="5,1" BorderThickness="1"
                            Background="Transparent" BorderBrush="#6A737D" MaxWidth="320">
                        <TextBlock Text="{Binding NearestBranch}" FontSize="10"
                                   TextTrimming="CharacterEllipsis" />
                    </Border>
                </StackPanel>

                <TextBlock Text="{loc:Tr History_Hover_NoBranches}" FontSize="11" Opacity="0.7"
                           VerticalAlignment="Center" IsVisible="{Binding HasNoRef}" />
            </WrapPanel>
        </DataTemplate>
    </Window.Resources>

    <Window.DataTemplates>
        <!-- "Where does this commit sit" card, stacked: SHA title, a HEAD chip, then its branch. Used by
             the graph-dot hover popup, where a tall narrow card suits the tooltip. (The diff pane uses
             the one-line variant below instead — see BranchInfoLine.) Content only (no card chrome) so
             it sits cleanly inside the tooltip's own frame. Fills in place: the SHA shows at once, the
             rest once git answers (IsLoaded), so an open popup never flickers empty. -->
        <DataTemplate DataType="vm:CommitBranchInfo">
            <StackPanel Spacing="5" MaxWidth="320">
                <TextBlock FontSize="12" TextWrapping="Wrap">
                    <Run Text="{loc:Tr History_Hover_CommitLabel}" Foreground="{DynamicResource SubtleForeground}" />
                    <Run Text="{Binding Sha}" FontFamily="Cascadia Mono,Consolas,monospace" FontWeight="SemiBold" />
                </TextBlock>

                <!-- Still querying git. -->
                <TextBlock Text="{loc:Tr History_Hover_Loading}" FontSize="11" Opacity="0.7"
                           IsVisible="{Binding !IsLoaded}" />

                <StackPanel Spacing="5" IsVisible="{Binding IsLoaded}">
                    <!-- HEAD reachability chip: green when reachable, muted grey when not. -->
                    <Border CornerRadius="3" Padding="6,1" HorizontalAlignment="Left" BorderThickness="1"
                            Background="#2C8F41" BorderBrush="#3FB950" IsVisible="{Binding InHead}">
                        <TextBlock Text="{loc:Tr History_Hover_InHead}" FontSize="10" Foreground="White" />
                    </Border>
                    <Border CornerRadius="3" Padding="6,1" HorizontalAlignment="Left" BorderThickness="1"
                            Background="#4D555E" BorderBrush="#6A737D" IsVisible="{Binding !InHead}">
                        <TextBlock Text="{loc:Tr History_Hover_NotInHead}" FontSize="10" Foreground="White" />
                    </Border>

                    <!-- One chip per ref pointing here, coloured by kind like the commit-row badges:
                         local orange, remote purple, tag green. -->
                    <ItemsControl ItemsSource="{Binding Branches}" IsVisible="{Binding HasBranches}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:GitRef">
                                <Border Classes.tag="{Binding IsTag}" Classes.remote="{Binding IsRemoteBranch}"
                                        CornerRadius="3" Padding="5,1" Margin="0,2,3,0" MaxWidth="230">
                                    <TextBlock Text="{Binding Name}" FontSize="10" Foreground="White"
                                               TextTrimming="CharacterEllipsis" />
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- "+N" for refs past the cap; outside the ItemsControl so the badge styles skip it. -->
                    <Border CornerRadius="3" Padding="5,1" BorderThickness="1" HorizontalAlignment="Left"
                            Background="#4D555E" BorderBrush="#6A737D" IsVisible="{Binding HasOverflow}">
                        <TextBlock Text="{Binding OverflowText}" FontSize="10" Foreground="White" />
                    </Border>

                    <!-- No ref points exactly here, but the branch is still known: either the line this
                         commit sits on ("On <branch>") or, if it was merged in, the branch it came from
                         per the merge commit ("Merged from <branch>", even if that ref is now deleted).
                         Outlined chip, distinct from the solid decoration chips above. -->
                    <StackPanel Orientation="Horizontal" Spacing="5" IsVisible="{Binding HasNearest}">
                        <TextBlock Text="{loc:Tr History_Hover_OnBranch}" FontSize="10" Opacity="0.6"
                                   VerticalAlignment="Center" IsVisible="{Binding !NearestIsMerge}" />
                        <TextBlock Text="{loc:Tr History_Hover_MergedFrom}" FontSize="10" Opacity="0.6"
                                   VerticalAlignment="Center" IsVisible="{Binding NearestIsMerge}" />
                        <Border CornerRadius="3" Padding="5,1" BorderThickness="1"
                                Background="Transparent" BorderBrush="#6A737D" MaxWidth="230">
                            <TextBlock Text="{Binding NearestBranch}" FontSize="10"
                                       TextTrimming="CharacterEllipsis" />
                        </Border>
                    </StackPanel>

                    <!-- Loaded, but nothing points here and nothing reaches it (a detached commit). -->
                    <TextBlock Text="{loc:Tr History_Hover_NoBranches}" FontSize="11" Opacity="0.7"
                               IsVisible="{Binding HasNoRef}" />
                </StackPanel>
            </StackPanel>
        </DataTemplate>
    </Window.DataTemplates>

    <Window.Styles>
        <!-- Ref badges: local branch (orange), remote (purple), tag (green). Fills are OPAQUE, not
             translucent, so the row's hover/selection highlight (which sits behind the pill) can't
             bleed through and wash the colour out. A brighter matching border defines the pill, and
             remote is purple — deliberately NOT the theme blue — so it can't blend into the blue
             highlight. Text is white for contrast on the solid fills. -->
        <Style Selector="Border.tag, Border.remote">
            <Setter Property="Background" Value="#33808080" />
        </Style>
        <Style Selector="ItemsControl > ContentPresenter > Border">
            <Setter Property="Background" Value="#A8402A" />
            <Setter Property="BorderBrush" Value="#F05133" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style Selector="ItemsControl > ContentPresenter > Border.remote">
            <Setter Property="Background" Value="#6E4CB8" />
            <Setter Property="BorderBrush" Value="#A371F7" />
        </Style>
        <Style Selector="ItemsControl > ContentPresenter > Border.tag">
            <Setter Property="Background" Value="#2C8F41" />
            <Setter Property="BorderBrush" Value="#3FB950" />
        </Style>

        <!-- Pane splitters: a wide transparent grab area with a thin centred handle, so the divider
             is discoverable and easy to grab. The handle follows the theme (SeparatorBrush) and
             brightens on hover (HoverStrongBrush). -->
        <Style Selector="GridSplitter.vsplit">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Cursor" Value="SizeWestEast" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}">
                        <Border Name="Handle" Width="2" CornerRadius="1" Margin="0,6"
                                HorizontalAlignment="Center" VerticalAlignment="Stretch"
                                Background="{DynamicResource SeparatorBrush}" />
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="GridSplitter.vsplit:pointerover /template/ Border#Handle">
            <Setter Property="Background" Value="{DynamicResource HoverStrongBrush}" />
        </Style>

        <Style Selector="GridSplitter.hsplit">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Cursor" Value="SizeNorthSouth" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}">
                        <Border Name="Handle" Height="2" CornerRadius="1" Margin="80,0"
                                HorizontalAlignment="Stretch" VerticalAlignment="Center"
                                Background="{DynamicResource SeparatorBrush}" />
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="GridSplitter.hsplit:pointerover /template/ Border#Handle">
            <Setter Property="Background" Value="{DynamicResource HoverStrongBrush}" />
        </Style>

        <!-- History column-resize grips: invisible until hovered, then a faint bar shows they're draggable. -->
        <Style Selector="Border.colgrip:pointerover">
            <Setter Property="Background" Value="{DynamicResource HoverStrongBrush}" />
        </Style>

        <!-- Frequent-projects rows: flat like list items (not the accent chip), with a hover highlight. -->
        <Style Selector="Button.frequent">
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="CornerRadius" Value="5" />
        </Style>
        <Style Selector="Button.frequent /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        <Style Selector="Button.frequent:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource AccentSubtleBrush}" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        <Style Selector="Button.frequent:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource AccentSubtlePressedBrush}" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>

        <!-- Per-row remove (✕) on the pinned list: quiet by default, red when hovered. -->
        <Style Selector="Button.repodelete">
            <Setter Property="Opacity" Value="0.35" />
            <Setter Property="Padding" Value="7,3" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="FontSize" Value="12" />
        </Style>
        <Style Selector="Button.repodelete /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        <Style Selector="Button.repodelete:pointerover">
            <Setter Property="Opacity" Value="1" />
            <Setter Property="Foreground" Value="White" />
        </Style>
        <Style Selector="Button.repodelete:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource RedBrush}" />
        </Style>
        <Style Selector="Button.repodelete:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource RedPressedBrush}" />
        </Style>
    </Window.Styles>

    <DockPanel Margin="16">

        <!-- Loading line. A long fetch/pull used to show only as a toolbar label, which both buried the
             signal and reflowed the toolbar as it appeared and vanished. A 2px indeterminate bar at the
             top says "something is running" without taking part in any other layout — it collapses to
             nothing when idle. -->
        <ProgressBar DockPanel.Dock="Top"
                     Height="2" Margin="0,0,0,10"
                     IsIndeterminate="True"
                     ShowProgressText="False"
                     MinWidth="0"
                     IsVisible="{Binding Workspace.IsWorking, FallbackValue=False}" />

        <!-- Advisory, so it can be dismissed: the hotkey stays inactive until it's rebound in
             ⚙ Settings, but the warning shouldn't hold the top of the window all session. -->
        <Border DockPanel.Dock="Top"
                IsVisible="{Binding HasHotkeyStatus}"
                Background="#40F05133"
                BorderBrush="#F05133"
                BorderThickness="1"
                CornerRadius="4"
                Padding="10,8"
                Margin="0,0,0,12">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <TextBlock Grid.Column="0" Text="{Binding HotkeyStatus}" TextWrapping="Wrap"
                           VerticalAlignment="Center" />
                <Button Grid.Column="1" Content="✕" Classes="header"
                        VerticalAlignment="Center" FontSize="12" Padding="6,1"
                        Command="{Binding DismissHotkeyStatusCommand}"
                        ToolTip.Tip="{loc:Tr Banner_Dismiss}" />
            </Grid>
        </Border>

        <Border DockPanel.Dock="Top"
                IsVisible="{Binding HasGitWarning}"
                Background="#40F05133"
                BorderBrush="#F05133"
                BorderThickness="1"
                CornerRadius="4"
                Padding="10,8"
                Margin="0,0,0,12">
            <TextBlock Text="{Binding GitWarning}" TextWrapping="Wrap" />
        </Border>

        <!-- Startup auto-check nudge; clicking it opens ⚙ Settings → Updates. -->
        <Border DockPanel.Dock="Top"
                IsVisible="{Binding HasUpdateBanner}"
                Background="#4058C0F0"
                BorderBrush="#588CF0"
                BorderThickness="1"
                CornerRadius="4"
                Padding="10,8"
                Margin="0,0,0,12"
                Cursor="Hand"
                Tapped="OnUpdateBannerClick">
            <TextBlock Text="{Binding UpdateBanner}" TextWrapping="Wrap" />
        </Border>

        <!-- Palette and workspace share the fill area; they're mutually exclusive via IsVisible.
             This wrapper fills as the DockPanel's last child so the palette can be centred within it. -->
        <Panel>

        <!-- Palette — a wide command-palette card: search + pinned list on the left, a
             "frequent projects" panel on the right so the width isn't wasted. -->
        <Grid IsVisible="{Binding IsPaletteVisible}"
              HorizontalAlignment="Center"
              MaxWidth="1000"
              ColumnDefinitions="2*,28,*">

            <!-- Left: search, pinned list, hints. -->
            <Grid Grid.Column="0" RowDefinitions="Auto,Auto,*,Auto">
                <Grid Grid.Row="0" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                    <TextBox Grid.Column="0"
                             x:Name="SearchBox"
                             PlaceholderText="{loc:Tr Palette_SearchPlaceholder}"
                             FontSize="16"
                             Padding="10,8"
                             Text="{Binding SearchText}" />
                    <Button Grid.Column="1"
                            Classes="primary"
                            Content="{loc:Tr Palette_Open}"
                            FontSize="14"
                            Padding="16,8"
                            VerticalAlignment="Stretch"
                            Click="OnOpenRepositoryClick"
                            ToolTip.Tip="{loc:Tr Palette_Open_Tooltip}" />
                    <Button Grid.Column="2"
                            Content="⚙"
                            FontSize="16"
                            Padding="12,8"
                            VerticalAlignment="Stretch"
                            Click="OnOpenSettingsClick"
                            ToolTip.Tip="{loc:Tr Palette_Settings_Tooltip}" />
                </Grid>

                <TextBlock Grid.Row="1"
                           IsVisible="{Binding HasStatusMessage}"
                           Text="{Binding StatusMessage}"
                           Foreground="#F05133"
                           Margin="2,8,0,0"
                           TextWrapping="Wrap" />

                <ListBox Grid.Row="2"
                         x:Name="RepoList"
                         Margin="0,12,0,0"
                         ItemsSource="{Binding Repos}"
                         SelectedItem="{Binding SelectedRepo}"
                         Background="Transparent"
                         BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="models:RepositoryItem">
                            <Grid ColumnDefinitions="*,Auto" Margin="0,2">
                                <StackPanel Grid.Column="0" Spacing="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding Path}" Opacity="0.55" FontSize="11" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                                <Button Grid.Column="1" Classes="repodelete" Content="✕"
                                        VerticalAlignment="Center"
                                        Command="{Binding $parent[ListBox].((vm:MainViewModel)DataContext).RemoveRepoCommand}"
                                        CommandParameter="{Binding}"
                                        ToolTip.Tip="{loc:Tr Palette_Remove_Tooltip}" />
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Empty states, mutually exclusive with the list having content -->
                <StackPanel Grid.Row="2"
                            IsVisible="{Binding !HasPinnedRepos}"
                            VerticalAlignment="Center"
                            Spacing="6">
                    <TextBlock Text="{loc:Tr Palette_NoReposPinned}"
                               HorizontalAlignment="Center"
                               Opacity="0.7" />
                    <TextBlock Text="{loc:Tr Palette_PressCtrlO}"
                               HorizontalAlignment="Center"
                               Opacity="0.45"
                               FontSize="12" />
                </StackPanel>

                <TextBlock Grid.Row="2"
                           IsVisible="{Binding HasNoMatches}"
                           Text="{loc:Tr Palette_NoMatches}"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"
                           Opacity="0.55" />

                <TextBlock Grid.Row="3"
                           Margin="2,10,0,0"
                           Opacity="0.4"
                           FontSize="11"
                           Text="{loc:Tr Palette_Hints}" />
            </Grid>

            <!-- Right: frequent projects (by open count), click to open. -->
            <DockPanel Grid.Column="2">
                <TextBlock DockPanel.Dock="Top"
                           Text="{loc:Tr Palette_Frequent_Header}"
                           FontSize="12" FontWeight="SemiBold" Opacity="0.55"
                           Margin="2,2,0,8" />
                <TextBlock DockPanel.Dock="Top"
                           Text="{loc:Tr Palette_Frequent_Empty}"
                           IsVisible="{Binding !HasFrequentRepos}"
                           TextWrapping="Wrap" Opacity="0.4" FontSize="12"
                           Margin="2,4,0,0" />
                <ItemsControl ItemsSource="{Binding FrequentRepos}"
                              IsVisible="{Binding HasFrequentRepos}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="models:FrequentRepo">
                            <Button Classes="frequent"
                                    Command="{Binding $parent[ItemsControl].((vm:MainViewModel)DataContext).OpenFrequentCommand}"
                                    CommandParameter="{Binding}"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Left"
                                    Margin="0,0,0,4">
                                <StackPanel Spacing="1">
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding Path}" Opacity="0.55" FontSize="11" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </DockPanel>
        </Grid>

        <!-- Workspace. The outer Panel keeps IsVisible bound to MainViewModel; the inner Grid
             switches DataContext to the WorkspaceViewModel. -->
        <Panel IsVisible="{Binding IsRepoOpen}">
        <Grid DataContext="{Binding Workspace}"
              x:DataType="vm:WorkspaceViewModel"
              RowDefinitions="Auto,*,Auto,Auto,Auto">

            <!-- One clean toolbar row. Branch and stash operations live in categorised flyouts
                 rather than a second row of buttons. -->
            <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
                <!-- Back sits on the far right with the ahead/behind counters; the toolbar is on the
                     left. Repo name and branch live in the OS title bar (see UpdateTitle). -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center"
                            Margin="10,0,0,0">
                    <!-- "Checking remote…" used to sit here; it appeared and disappeared mid-session and
                         reflowed the whole toolbar. The loading line at the top of the window says the
                         same thing without consuming width. -->
                    <TextBlock VerticalAlignment="Center" Opacity="0.6" FontSize="12"
                               Text="{Binding Ahead, StringFormat='↑{0}'}"
                               IsVisible="{Binding Ahead}" />
                    <TextBlock VerticalAlignment="Center" Opacity="0.6" FontSize="12"
                               Text="{Binding Behind, StringFormat='↓{0}'}"
                               IsVisible="{Binding Behind}" />
                    <!-- Who you are: the commit author and the account allowed to push. They're
                         independent, and them disagreeing is the classic trap, so both live here. -->
                    <!-- Capped: an identity name is arbitrary text, and letting it size the toolbar
                         would wrap the button row on a long one. -->
                    <Button Classes="header" VerticalAlignment="Center"
                            MaxWidth="150" ClipToBounds="True"
                            Content="{Binding IdentityLabel}"
                            ToolTip.Tip="{loc:Tr Account_Tooltip}">
                        <Button.Flyout>
                            <!-- gh is a subprocess, so the account list is read when the flyout opens
                                 rather than on every refresh. -->
                            <Flyout Placement="BottomEdgeAlignedRight" Opened="OnAccountFlyoutOpened">
                                <StackPanel Width="340" Spacing="8" x:DataType="vm:WorkspaceViewModel">
                                    <TextBlock Text="{loc:Tr Account_CommitIdentity}" FontSize="10" Opacity="0.5" />
                                    <TextBlock Text="{Binding IdentitySummary}" FontSize="12" TextWrapping="Wrap" />

                                    <TextBox Text="{Binding IdentityNameInput}" FontSize="12"
                                             VerticalContentAlignment="Center"
                                             PlaceholderText="{loc:Tr Account_Name}" />
                                    <TextBox Text="{Binding IdentityEmailInput}" FontSize="12"
                                             VerticalContentAlignment="Center"
                                             PlaceholderText="{loc:Tr Account_Email}" />

                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
                                        <CheckBox Grid.Column="0" FontSize="11" VerticalAlignment="Center"
                                                  Content="{loc:Tr Account_RepoOnly}"
                                                  IsChecked="{Binding IdentityRepoOnly}"
                                                  ToolTip.Tip="{loc:Tr Account_RepoOnly_Tooltip}" />
                                        <Button Grid.Column="1" Classes="primary" FontSize="12"
                                                Content="{loc:Tr Account_Apply}"
                                                Command="{Binding ApplyIdentityCommand}" />
                                    </Grid>

                                    <Button FontSize="11" HorizontalAlignment="Left"
                                            Content="{loc:Tr Account_ClearRepo}"
                                            IsVisible="{Binding Identity.IsRepoOverride}"
                                            Command="{Binding ClearRepoIdentityCommand}"
                                            ToolTip.Tip="{loc:Tr Account_ClearRepo_Tooltip}" />

                                    <TextBlock Text="{loc:Tr Account_Saved}" FontSize="10" Opacity="0.5" />
                                    <ItemsControl ItemsSource="{Binding SavedIdentities}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="models:SavedIdentity">
                                                <Button Classes="frequent" HorizontalAlignment="Stretch"
                                                        HorizontalContentAlignment="Left" FontSize="11"
                                                        Click="OnUseSavedIdentityClick">
                                                    <TextBlock Text="{Binding}" TextTrimming="CharacterEllipsis" />
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <Separator Margin="0,2" />

                                    <TextBlock Text="{loc:Tr Account_GitHub}" FontSize="10" Opacity="0.5" />
                                    <TextBlock Text="{loc:Tr Account_GhMissing}" FontSize="11" Opacity="0.6"
                                               TextWrapping="Wrap" IsVisible="{Binding !IsGhAvailable}" />

                                    <ItemsControl ItemsSource="{Binding GitHubAccounts}"
                                                  IsVisible="{Binding IsGhAvailable}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="services:GhAccount">
                                                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="6" Margin="0,2">
                                                    <TextBlock Grid.Column="0" VerticalAlignment="Center" FontSize="12"
                                                               Text="{Binding Login}" TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Grid.Column="1" VerticalAlignment="Center" FontSize="10"
                                                               Opacity="0.55" Text="{loc:Tr Account_Active}"
                                                               IsVisible="{Binding IsActive}" />
                                                    <Button Grid.Column="1" FontSize="11" Content="{loc:Tr Account_Switch}"
                                                            IsVisible="{Binding !IsActive}"
                                                            Click="OnSwitchGitHubAccountClick" />
                                                    <Button Grid.Column="2" FontSize="11" Content="{loc:Tr Account_Logout}"
                                                            Click="OnGitHubLogoutClick" />
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <Button FontSize="12" HorizontalAlignment="Left"
                                            Content="{loc:Tr Account_Login}"
                                            IsVisible="{Binding IsGhAvailable}"
                                            Command="{Binding GitHubLoginCommand}"
                                            ToolTip.Tip="{loc:Tr Account_Login_Tooltip}" />
                                </StackPanel>
                            </Flyout>
                        </Button.Flyout>
                    </Button>

                    <Button Content="{loc:Tr Toolbar_Back}" Click="OnBackClick" VerticalAlignment="Center"
                            ToolTip.Tip="{loc:Tr Toolbar_Back_Tooltip}" />
                </StackPanel>

                <!-- WrapPanel (not StackPanel), left-aligned, so a narrow window wraps the toolbar
                     onto a second row instead of overflowing. -->
                <WrapPanel Grid.Column="0" HorizontalAlignment="Left" VerticalAlignment="Center"
                           IsEnabled="{Binding !IsBusy}">
                    <WrapPanel.Styles>
                        <!-- WrapPanel has no Spacing; a uniform per-child margin spaces the buttons
                             and, when it wraps, the rows too. -->
                        <Style Selector="WrapPanel > :is(Control)">
                            <Setter Property="Margin" Value="0,2,6,2" />
                        </Style>
                    </WrapPanel.Styles>
                    <!-- The active view is the one wearing the accent. -->
                    <Button Content="{loc:Tr Toolbar_Changes}" Command="{Binding ShowChangesCommand}"
                            Classes.primary="{Binding !IsHistoryMode}" />
                    <Button Content="{loc:Tr Toolbar_History}" Command="{Binding ShowHistoryCommand}"
                            Classes.primary="{Binding IsHistoryMode}" />

                    <Rectangle Width="1" Height="22" Fill="{DynamicResource SeparatorBrush}" VerticalAlignment="Center" />

                    <!-- Primary click runs the plain action; the chevron opens the variants,
                         mirroring VS Code's Pull/Fetch split menus. -->
                    <SplitButton Content="{loc:Tr Toolbar_Fetch}" Command="{Binding FetchCommand}"
                                 ToolTip.Tip="{loc:Tr Toolbar_Fetch_Tooltip}">
                        <SplitButton.Flyout>
                            <MenuFlyout Placement="BottomEdgeAlignedRight">
                                <MenuItem Header="{loc:Tr Toolbar_FetchPrune}" Command="{Binding FetchPruneCommand}"
                                          ToolTip.Tip="{loc:Tr Toolbar_FetchPrune_Tooltip}" />
                                <MenuItem Header="{loc:Tr Toolbar_FetchAll}" Command="{Binding FetchAllCommand}"
                                          ToolTip.Tip="{loc:Tr Toolbar_FetchAll_Tooltip}" />
                            </MenuFlyout>
                        </SplitButton.Flyout>
                    </SplitButton>
                    <!-- Pull carries the "out of sync" nudge itself: it shows the behind count and
                         wears the accent when the upstream is ahead, so there's no separate button. -->
                    <SplitButton Content="{Binding PullLabel}" Command="{Binding PullCommand}"
                                 Classes.primary="{Binding IsBehind}"
                                 ToolTip.Tip="{Binding PullTooltip}">
                        <SplitButton.Flyout>
                            <MenuFlyout Placement="BottomEdgeAlignedRight">
                                <MenuItem Header="{loc:Tr Toolbar_PullRebase}" Command="{Binding PullRebaseCommand}"
                                          ToolTip.Tip="{loc:Tr Toolbar_PullRebase_Tooltip}" />
                                <MenuItem Header="{loc:Tr Toolbar_PullFrom}" Command="{Binding PullFromCommand}"
                                          ToolTip.Tip="{loc:Tr Toolbar_PullFrom_Tooltip}" />
                            </MenuFlyout>
                        </SplitButton.Flyout>
                    </SplitButton>
                    <!-- Push mirrors Pull: shows the ahead count and wears the accent when the local
                         branch has commits the remote doesn't. -->
                    <SplitButton Content="{Binding PushLabel}" Command="{Binding PushCommand}"
                                 Classes.primary="{Binding IsAhead}"
                                 ToolTip.Tip="{Binding PushTooltip}">
                        <SplitButton.Flyout>
                            <MenuFlyout Placement="BottomEdgeAlignedRight">
                                <MenuItem Header="{loc:Tr Toolbar_PushTo}" Command="{Binding PushToCommand}"
                                          ToolTip.Tip="{loc:Tr Toolbar_PushTo_Tooltip}" />
                            </MenuFlyout>
                        </SplitButton.Flyout>
                    </SplitButton>

                    <Button Content="{loc:Tr Toolbar_Branch}">
                        <Button.Flyout>
                            <Flyout Placement="BottomEdgeAlignedRight">
                                <StackPanel Width="300" Spacing="8" x:DataType="vm:WorkspaceViewModel">
                                    <TextBlock Text="{loc:Tr Branch_CreateHeader}" FontSize="10" Opacity="0.5" />
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
                                        <TextBox Grid.Column="0" PlaceholderText="{loc:Tr Branch_NewNamePlaceholder}"
                                                 Text="{Binding NewBranchName}" VerticalContentAlignment="Center" />
                                        <Button Grid.Column="1" Content="{loc:Tr Branch_Create}" Command="{Binding CreateBranchCommand}" />
                                    </Grid>
                                    <!-- Where the branch starts. Defaults to the checked-out branch; takes any
                                         branch/tag/SHA, so free text is accepted even if it isn't in the list. -->
                                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="6">
                                        <TextBlock Grid.Column="0" Text="{loc:Tr Branch_CreateFrom}"
                                                   FontSize="10" Opacity="0.5" VerticalAlignment="Center" />
                                        <AutoCompleteBox Grid.Column="1"
                                                         Text="{Binding NewBranchFrom, Mode=TwoWay}"
                                                         ItemsSource="{Binding BaseRefs}"
                                                         FilterMode="Custom"
                                                         ItemFilter="{x:Static vm:FuzzyFilters.Any}"
                                                         MinimumPrefixLength="0"
                                                         MaxDropDownHeight="200"
                                                         PlaceholderText="{loc:Tr Branch_CreateFromPlaceholder}"
                                                         FontSize="12" />
                                    </Grid>

                                    <Separator Margin="0,4" />

                                    <TextBlock Text="{loc:Tr Branch_ListHeader}" FontSize="10" Opacity="0.5" />
                                    <TextBox Text="{Binding BranchSearch}" PlaceholderText="{loc:Tr Branch_Search}"
                                             VerticalContentAlignment="Center" FontSize="12" />
                                    <ListBox MaxHeight="200"
                                             ItemsSource="{Binding FilteredBranches}"
                                             SelectedItem="{Binding SelectedBranch}">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate x:DataType="models:GitBranch">
                                                <Grid ColumnDefinitions="*,Auto">
                                                    <TextBlock Grid.Column="0" Text="{Binding Name}" />
                                                    <TextBlock Grid.Column="1" Text="{loc:Tr Branch_Current}" FontSize="10" Opacity="0.5"
                                                               IsVisible="{Binding IsCurrent}" />
                                                </Grid>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="6">
                                        <Button Grid.Column="0" Content="{loc:Tr Branch_Checkout}" HorizontalAlignment="Stretch"
                                                HorizontalContentAlignment="Center" Command="{Binding CheckoutCommand}" />
                                        <Button Grid.Column="1" Content="{loc:Tr Branch_Merge}" HorizontalAlignment="Stretch"
                                                HorizontalContentAlignment="Center" Command="{Binding MergeCommand}" />
                                        <Button Grid.Column="2" Classes="danger" Content="{loc:Tr Branch_Delete}" HorizontalAlignment="Stretch"
                                                HorizontalContentAlignment="Center" Command="{Binding DeleteBranchCommand}" />
                                    </Grid>
                                    <!-- Upstream actions get their own 2-col row: "Set/Unset upstream" are too
                                         wide to sit three-across in a 300px flyout without truncating. -->
                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="6">
                                        <Button Grid.Column="0" Content="{loc:Tr Branch_SetUpstream}" HorizontalAlignment="Stretch"
                                                HorizontalContentAlignment="Center" Command="{Binding SetUpstreamCommand}" />
                                        <Button Grid.Column="1" Content="{loc:Tr Branch_UnsetUpstream}" HorizontalAlignment="Stretch"
                                                HorizontalContentAlignment="Center" Command="{Binding UnsetUpstreamCommand}" />
                                    </Grid>
                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="6">
                                        <Button Grid.Column="0" Content="{loc:Tr Branch_Rename}" HorizontalAlignment="Stretch"
                                                HorizontalContentAlignment="Center" Command="{Binding RenameBranchCommand}" />
                                        <Button Grid.Column="1" Content="{loc:Tr Branch_Compare}" HorizontalAlignment="Stretch"
                                                HorizontalContentAlignment="Center" Click="OnCompareBranchClick"
                                                ToolTip.Tip="{loc:Tr Branch_Compare_Tooltip}" />
                                    </Grid>
                                    <TextBlock Text="{loc:Tr Branch_ActionsHint}"
                                               FontSize="10" Opacity="0.4" TextWrapping="Wrap" />
                                </StackPanel>
                            </Flyout>
                        </Button.Flyout>
                    </Button>

                    <Button x:Name="StashButton" Content="{loc:Tr Toolbar_Stash}">
                        <Button.Flyout>
                            <Flyout Placement="BottomEdgeAlignedRight">
                                <StackPanel Width="340" Spacing="6" x:DataType="vm:WorkspaceViewModel">
                                    <!-- Create a stash: tracked, incl. untracked, or index only. -->
                                    <Button Content="{loc:Tr Stash_Changes}" HorizontalAlignment="Stretch"
                                            HorizontalContentAlignment="Center" Command="{Binding StashPushCommand}" />
                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="6">
                                        <Button Grid.Column="0" Content="{loc:Tr Stash_Untracked}" HorizontalAlignment="Stretch"
                                                HorizontalContentAlignment="Center" Command="{Binding StashUntrackedCommand}" />
                                        <Button Grid.Column="1" Content="{loc:Tr Stash_Staged}" HorizontalAlignment="Stretch"
                                                HorizontalContentAlignment="Center" Command="{Binding StashStagedCommand}" />
                                    </Grid>

                                    <Separator Margin="0,2" />

                                    <!-- Act on the most recent stash. -->
                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="6">
                                        <Button Grid.Column="0" Content="{loc:Tr Stash_ApplyLatest}" HorizontalAlignment="Stretch"
                                                HorizontalContentAlignment="Center" IsEnabled="{Binding HasStashes}"
                                                Command="{Binding ApplyLatestStashCommand}" />
                                        <Button Grid.Column="1" Content="{loc:Tr Stash_PopLatest}" HorizontalAlignment="Stretch"
                                                HorizontalContentAlignment="Center" IsEnabled="{Binding HasStashes}"
                                                Command="{Binding StashPopCommand}" />
                                    </Grid>

                                    <Separator Margin="0,2" />

                                    <Grid ColumnDefinitions="*,Auto">
                                        <TextBlock Grid.Column="0" Text="{loc:Tr Stash_ListHeader}" FontSize="10" Opacity="0.5"
                                                   VerticalAlignment="Center" />
                                        <Button Grid.Column="1" Content="{loc:Tr Stash_DropAll}" FontSize="11" Padding="8,2"
                                                IsEnabled="{Binding HasStashes}" Command="{Binding DropAllStashesCommand}" />
                                    </Grid>

                                    <!-- Each stash: view its patch, apply/pop it, or drop it. -->
                                    <ListBox MaxHeight="220" ItemsSource="{Binding Stashes}">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate x:DataType="models:StashEntry">
                                                <Grid ColumnDefinitions="*,Auto" ToolTip.Tip="{Binding Description}">
                                                    <TextBlock Grid.Column="0" Text="{Binding Description}"
                                                               TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="2">
                                                        <Button Classes="header" FontSize="11" Padding="6,1" Content="{loc:Tr Stash_View}"
                                                                Click="OnViewStashClick" />
                                                        <Button Classes="header" FontSize="11" Padding="6,1" Content="{loc:Tr Stash_Apply}"
                                                                Command="{Binding $parent[ListBox].((vm:WorkspaceViewModel)DataContext).ApplyStashCommand}"
                                                                CommandParameter="{Binding}" />
                                                        <Button Classes="header" FontSize="11" Padding="6,1" Content="{loc:Tr Stash_Pop}"
                                                                Command="{Binding $parent[ListBox].((vm:WorkspaceViewModel)DataContext).PopStashAtCommand}"
                                                                CommandParameter="{Binding}" />
                                                        <Button Classes="header" FontSize="11" Padding="6,1" Content="{loc:Tr Stash_Drop}"
                                                                Command="{Binding $parent[ListBox].((vm:WorkspaceViewModel)DataContext).DropStashCommand}"
                                                                CommandParameter="{Binding}" />
                                                    </StackPanel>
                                                </Grid>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                    <TextBlock Text="{loc:Tr Stash_None}" IsVisible="{Binding !HasStashes}" Opacity="0.4" />
                                </StackPanel>
                            </Flyout>
                        </Button.Flyout>
                    </Button>

                    <Button x:Name="TagsButton" Content="{loc:Tr Toolbar_Tags}">
                        <Button.Flyout>
                            <Flyout Placement="BottomEdgeAlignedRight">
                                <StackPanel Width="330" Spacing="6" x:DataType="vm:WorkspaceViewModel">
                                    <!-- Create a tag at HEAD, or push all tags to the remote. -->
                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="6">
                                        <Button Grid.Column="0" Content="{loc:Tr Tag_Create}" HorizontalAlignment="Stretch"
                                                HorizontalContentAlignment="Center" Command="{Binding CreateTagCommand}" />
                                        <Button Grid.Column="1" Content="{loc:Tr Tag_PushAll}" HorizontalAlignment="Stretch"
                                                HorizontalContentAlignment="Center" IsEnabled="{Binding HasTags}"
                                                Command="{Binding PushTagsCommand}" />
                                    </Grid>

                                    <Separator Margin="0,2" />

                                    <!-- Header: a select-all tick, the label, then bulk-delete the selection. -->
                                    <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="4">
                                        <CheckBox Grid.Column="0" IsChecked="{Binding AllTagsSelected, Mode=TwoWay}"
                                                  IsEnabled="{Binding HasTags}" Margin="0,0,6,0" VerticalAlignment="Center"
                                                  ToolTip.Tip="{loc:Tr Tag_SelectAll_Tooltip}" />
                                        <TextBlock Grid.Column="1" Text="{loc:Tr Tag_ListHeader}" FontSize="10" Opacity="0.5"
                                                   VerticalAlignment="Center" />
                                        <Button Grid.Column="2" Content="{loc:Tr Tag_Delete}" FontSize="11" Padding="8,2"
                                                IsEnabled="{Binding HasSelectedTags}" Command="{Binding DeleteSelectedTagsCommand}"
                                                ToolTip.Tip="{loc:Tr Tag_Delete_Tooltip}" />
                                        <Button Grid.Column="3" Content="{loc:Tr Tag_DeleteRemote}" FontSize="11" Padding="8,2"
                                                IsEnabled="{Binding HasSelectedTags}" Command="{Binding DeleteSelectedRemoteTagsCommand}"
                                                ToolTip.Tip="{loc:Tr Tag_DeleteRemote_Tooltip}" />
                                    </Grid>

                                    <ListBox MaxHeight="220" ItemsSource="{Binding Tags}">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate x:DataType="vm:TagItem">
                                                <Grid ColumnDefinitions="Auto,*,Auto" ToolTip.Tip="{Binding Name}">
                                                    <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                              Margin="0,0,6,0" VerticalAlignment="Center" />
                                                    <TextBlock Grid.Column="1" Text="{Binding Name}"
                                                               TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                                    <!-- On the remote (synced) vs local-only (not pushed). -->
                                                    <TextBlock Grid.Column="2" Text="{loc:Tr Tag_OnRemote}"
                                                               IsVisible="{Binding IsOnRemote}" FontSize="10"
                                                               VerticalAlignment="Center" Foreground="#4CAF50" />
                                                    <TextBlock Grid.Column="2" Text="{loc:Tr Tag_LocalOnly}"
                                                               IsVisible="{Binding IsLocalOnly}" FontSize="10"
                                                               VerticalAlignment="Center" Opacity="0.5" />
                                                </Grid>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                    <TextBlock Text="{loc:Tr Tag_None}" IsVisible="{Binding !HasTags}" Opacity="0.4" />
                                </StackPanel>
                            </Flyout>
                        </Button.Flyout>
                    </Button>

                    <Button Content="&gt;_" FontFamily="Cascadia Mono,Consolas,monospace"
                            Click="OnShowCommandLogClick"
                            ToolTip.Tip="{loc:Tr Toolbar_CommandLog_Tooltip}" />

                    <Button Content="⟲" Click="OnShowReflogClick" ToolTip.Tip="{loc:Tr Toolbar_Reflog_Tooltip}" />

                    <Button Content="⟳" Command="{Binding RefreshCommand}" ToolTip.Tip="{loc:Tr Toolbar_Refresh_Tooltip}" />
                </WrapPanel>
            </Grid>

            <!-- Left pane: file lists (Changes) or the commit graph (History). Right pane: diff.
                 The splitter owns the width from here on — deliberately not bound to the view
                 model, so switching modes never overrides where the user dragged it. -->
            <Grid Grid.Row="1" Margin="0,14,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="480" MinWidth="240" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="*" MinWidth="280" />
                </Grid.ColumnDefinitions>

                <GridSplitter Grid.Column="1"
                              x:Name="MainSplitter"
                              Classes="vsplit"
                              ResizeDirection="Columns"
                              ResizeBehavior="PreviousAndNext" />

                <Grid Grid.Column="0" RowDefinitions="*,10,*" IsVisible="{Binding !IsHistoryMode}">

                    <!-- Draggable divider between the Unstaged and Staged lists. -->
                    <GridSplitter Grid.Row="1" Classes="hsplit"
                                  ResizeDirection="Rows" ResizeBehavior="PreviousAndNext" />

                    <DockPanel Grid.Row="0">
                        <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,4">
                            <TextBlock Grid.Column="0" Text="{loc:Tr Changes_Unstaged}" FontWeight="SemiBold" VerticalAlignment="Center" />
                            <Button Grid.Column="1" Content="{loc:Tr Changes_StageAll}" FontSize="11"
                                    Command="{Binding StageAllCommand}" IsEnabled="{Binding !IsBusy}" />
                        </Grid>
                        <Border BorderBrush="#30808080" BorderThickness="1" CornerRadius="4">
                            <Panel>
                                <ListBox x:Name="UnstagedList"
                                         Background="Transparent"
                                         SelectionMode="Multiple"
                                         ItemsSource="{Binding UnstagedFiles}"
                                         SelectedItem="{Binding SelectedUnstagedFile}">
                                    <ListBox.ContextFlyout>
                                        <MenuFlyout>
                                            <MenuItem Header="{loc:Tr Changes_OpenFile}" Click="OnOpenFileClick" />
                                            <Separator />
                                            <MenuItem Header="{loc:Tr Changes_StageSelected}" Click="OnStageSelectedClick" />
                                            <Separator />
                                            <MenuItem Header="{loc:Tr Changes_DiscardChanges}" Click="OnDiscardSelectedClick" />
                                            <Separator />
                                            <MenuItem Header="{loc:Tr Changes_FileHistory}" Click="OnShowFileHistoryClick" />
                                            <MenuItem Header="{loc:Tr Changes_Blame}" Click="OnShowBlameClick" />
                                            <MenuItem Header="{loc:Tr Changes_OpenOnRemote}" Click="OnOpenFileOnRemoteClick" />
                                        </MenuFlyout>
                                    </ListBox.ContextFlyout>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate x:DataType="models:GitStatusEntry">
                                            <Grid ColumnDefinitions="Auto,*">
                                                <TextBlock Grid.Column="0" Text="{Binding UnstagedBadge}" Width="16"
                                                           FontWeight="SemiBold" FontFamily="Cascadia Mono,Consolas,monospace"
                                                           Foreground="{Binding UnstagedBadge, Converter={StaticResource FileStatusBrush}}" />
                                                <TextBlock Grid.Column="1" Text="{Binding Path}" TextTrimming="CharacterEllipsis" />
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                <TextBlock Text="{loc:Tr Changes_NoUnstaged}"
                                           IsVisible="{Binding !HasUnstagedFiles}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Opacity="0.35" IsHitTestVisible="False" />
                            </Panel>
                        </Border>
                    </DockPanel>

                    <DockPanel Grid.Row="2">
                        <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,4">
                            <TextBlock Grid.Column="0" Text="{loc:Tr Changes_Staged}" FontWeight="SemiBold" VerticalAlignment="Center" />
                            <Button Grid.Column="1" Content="{loc:Tr Changes_UnstageAll}" FontSize="11"
                                    Command="{Binding UnstageAllCommand}" IsEnabled="{Binding !IsBusy}" />
                        </Grid>
                        <Border BorderBrush="#30808080" BorderThickness="1" CornerRadius="4">
                            <Panel>
                                <ListBox x:Name="StagedList"
                                         Background="Transparent"
                                         SelectionMode="Multiple"
                                         ItemsSource="{Binding StagedFiles}"
                                         SelectedItem="{Binding SelectedStagedFile}">
                                    <ListBox.ContextFlyout>
                                        <MenuFlyout>
                                            <MenuItem Header="{loc:Tr Changes_OpenFile}" Click="OnOpenFileClick" />
                                            <Separator />
                                            <MenuItem Header="{loc:Tr Changes_UnstageSelected}" Click="OnUnstageSelectedClick" />
                                            <Separator />
                                            <MenuItem Header="{loc:Tr Changes_FileHistory}" Click="OnShowFileHistoryClick" />
                                            <MenuItem Header="{loc:Tr Changes_Blame}" Click="OnShowBlameClick" />
                                            <MenuItem Header="{loc:Tr Changes_OpenOnRemote}" Click="OnOpenFileOnRemoteClick" />
                                        </MenuFlyout>
                                    </ListBox.ContextFlyout>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate x:DataType="models:GitStatusEntry">
                                            <Grid ColumnDefinitions="Auto,*">
                                                <TextBlock Grid.Column="0" Text="{Binding StagedBadge}" Width="16"
                                                           FontWeight="SemiBold" FontFamily="Cascadia Mono,Consolas,monospace"
                                                           Foreground="{Binding StagedBadge, Converter={StaticResource FileStatusBrush}}" />
                                                <TextBlock Grid.Column="1" Text="{Binding Path}" TextTrimming="CharacterEllipsis" />
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                <TextBlock Text="{loc:Tr Changes_NothingStaged}"
                                           IsVisible="{Binding !HasStagedFiles}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Opacity="0.35" IsHitTestVisible="False" />
                            </Panel>
                        </Border>
                    </DockPanel>
                </Grid>

                <!-- History: commit list with the lane graph drawn over its left gutter. -->
                <!-- ClipToBounds: a backstop so nothing in here can ever paint over the diff pane, whatever
                     the pane is narrowed to. -->
                <DockPanel Grid.Column="0" x:Name="HistoryPane" ClipToBounds="True"
                           IsVisible="{Binding IsHistoryMode}">
                    <!-- The filters live in a '*' column, not 'Auto': an Auto column takes the group's full
                         desired width, which overflowed a narrow pane and drew across the diff. Constrained
                         here, the WrapPanel drops them onto a second line instead. -->
                    <Grid DockPanel.Dock="Top" ColumnDefinitions="Auto,*" Margin="0,0,0,4">
                        <TextBlock Grid.Column="0" Text="{loc:Tr History_Header}" FontWeight="SemiBold"
                                   VerticalAlignment="Center" Margin="0,0,12,0" />

                        <!-- Every filter (search included) is a dropdown, so nothing sits inline stealing
                             width. The File scope (incl. right-click "File history") shows in the Search ▾
                             label. Margins rather than Spacing, so wrapped lines stay evenly gapped. -->
                        <WrapPanel Grid.Column="1" Orientation="Horizontal"
                                   HorizontalAlignment="Right" VerticalAlignment="Center">
                            <!-- Unified search: one dropdown holding the Message/File scope toggle, the
                                 input, and (File scope) a click-to-pick list of matching paths. -->
                            <Button x:Name="SearchDropdownButton" Classes="header" FontWeight="Normal"
                                    Margin="12,2,0,2"
                                    Content="{Binding SearchFilterLabel}"
                                    ToolTip.Tip="{loc:Tr History_SearchType_Tooltip}">
                                <Button.Flyout>
                                    <Flyout Placement="BottomEdgeAlignedRight">
                                        <StackPanel Width="300" Spacing="8" x:DataType="vm:WorkspaceViewModel">
                                            <Grid ColumnDefinitions="*,Auto">
                                                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10">
                                                    <RadioButton GroupName="searchScope" FontSize="12"
                                                                 Content="{loc:Tr History_SearchType_Message}"
                                                                 IsChecked="{Binding IsMessageSearch, Mode=OneWay}"
                                                                 Command="{Binding UseMessageSearchCommand}" />
                                                    <RadioButton GroupName="searchScope" FontSize="12"
                                                                 Content="{loc:Tr History_SearchType_File}"
                                                                 IsChecked="{Binding IsFileSearch, Mode=OneWay}"
                                                                 Command="{Binding UseFileSearchCommand}" />
                                                    <RadioButton GroupName="searchScope" FontSize="12"
                                                                 Content="{loc:Tr History_SearchType_Content}"
                                                                 IsChecked="{Binding IsContentSearch, Mode=OneWay}"
                                                                 Command="{Binding UseContentSearchCommand}" />
                                                </StackPanel>
                                                <Button Grid.Column="1" Content="{loc:Tr History_Clear}" FontSize="11" Padding="8,2"
                                                        IsEnabled="{Binding HasSearchFilter}"
                                                        Command="{Binding ClearSearchCommand}" />
                                            </Grid>
                                            <TextBox x:Name="SearchInput"
                                                     Text="{Binding SearchText}"
                                                     PlaceholderText="{Binding SearchPlaceholder}"
                                                     VerticalContentAlignment="Center"
                                                     FontSize="12" Padding="6,4"
                                                     KeyDown="OnSearchBoxKeyDown" />
                                            <!-- File scope only: the fuzzy-matched historical paths. Bounding the
                                                 ListBox itself (rather than wrapping it in a ScrollViewer) keeps its
                                                 VirtualizingStackPanel realizing only the visible rows — a wrapping
                                                 ScrollViewer hands it an unbounded measure and defeats virtualization. -->
                                            <Border IsVisible="{Binding IsFileSearch}"
                                                    BorderBrush="#30808080" BorderThickness="1" CornerRadius="3">
                                                <ListBox x:Name="PathList"
                                                         MaxHeight="240"
                                                         ItemsSource="{Binding FilteredPathSuggestions}"
                                                         SelectionChanged="OnPathSuggestionSelected"
                                                         Background="Transparent" FontSize="12" />
                                            </Border>
                                        </StackPanel>
                                    </Flyout>
                                </Button.Flyout>
                            </Button>
                            <Button Classes="header" FontWeight="Normal"
                                    Content="{Binding AuthorFilterLabel}"
                                    ToolTip.Tip="{loc:Tr History_AuthorFilter_Tooltip}">
                                <Button.Flyout>
                                    <Flyout Placement="BottomEdgeAlignedRight">
                                        <StackPanel Width="250" Spacing="6" x:DataType="vm:WorkspaceViewModel">
                                            <Grid ColumnDefinitions="*,Auto">
                                                <TextBlock Grid.Column="0" Text="{loc:Tr History_ShowOnlyAuthors}"
                                                           FontSize="10" Opacity="0.5" VerticalAlignment="Center" />
                                                <Button Grid.Column="1" Content="{loc:Tr History_Clear}" FontSize="11" Padding="8,2"
                                                        IsEnabled="{Binding HasAuthorFilter}"
                                                        Command="{Binding ClearAuthorFilterCommand}" />
                                            </Grid>
                                            <TextBox Text="{Binding AuthorFilterSearch}" PlaceholderText="{loc:Tr History_SearchAuthors}"
                                                     VerticalContentAlignment="Center"
                                                     FontSize="12" Padding="6,3" />
                                            <ScrollViewer MaxHeight="280">
                                                <ItemsControl ItemsSource="{Binding FilteredAuthorFilters}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate x:DataType="vm:FilterOption">
                                                            <CheckBox Content="{Binding Name}"
                                                                      IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                                      Margin="0,1" />
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </ScrollViewer>
                                        </StackPanel>
                                    </Flyout>
                                </Button.Flyout>
                            </Button>
                            <Button Classes="header" FontWeight="Normal"
                                    Content="{Binding BranchFilterLabel}"
                                    ToolTip.Tip="{loc:Tr History_BranchFilter_Tooltip}">
                                <Button.Flyout>
                                    <Flyout Placement="BottomEdgeAlignedRight">
                                        <StackPanel Width="270" Spacing="6" x:DataType="vm:WorkspaceViewModel">
                                            <Grid ColumnDefinitions="*,Auto">
                                                <TextBlock Grid.Column="0" Text="{loc:Tr History_ShowOnlyBranches}"
                                                           FontSize="10" Opacity="0.5" VerticalAlignment="Center" />
                                                <Button Grid.Column="1" Content="{loc:Tr History_Clear}" FontSize="11" Padding="8,2"
                                                        IsEnabled="{Binding HasBranchFilter}"
                                                        Command="{Binding ClearBranchFilterCommand}" />
                                            </Grid>
                                            <TextBox Text="{Binding BranchFilterSearch}" PlaceholderText="{loc:Tr History_SearchBranches}"
                                                     VerticalContentAlignment="Center"
                                                     FontSize="12" Padding="6,3" />
                                            <ScrollViewer MaxHeight="280">
                                                <ItemsControl ItemsSource="{Binding FilteredBranchFilters}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate x:DataType="vm:FilterOption">
                                                            <CheckBox Content="{Binding Name}"
                                                                      IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                                      Margin="0,1" />
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </ScrollViewer>
                                        </StackPanel>
                                    </Flyout>
                                </Button.Flyout>
                            </Button>
                            <Button Classes="header"
                                    Margin="12,2,0,2"
                                    Content="{loc:Tr History_GraphOrder}"
                                    IsVisible="{Binding !ShowGraph}"
                                    Command="{Binding ResetSortCommand}"
                                    ToolTip.Tip="{loc:Tr History_GraphOrder_Tooltip}" />
                            <CheckBox Content="{loc:Tr History_FirstParentOnly}"
                                      FontSize="11" Margin="12,2,0,2"
                                      IsChecked="{Binding FirstParentOnly}"
                                      ToolTip.Tip="{loc:Tr History_FirstParentOnly_Tooltip}" />
                            <CheckBox Content="{loc:Tr History_MergesOnly}"
                                      FontSize="11" Margin="12,2,0,2"
                                      IsChecked="{Binding MergesOnly}"
                                      ToolTip.Tip="{loc:Tr History_MergesOnly_Tooltip}" />
                        </WrapPanel>
                    </Grid>

                    <Border BorderBrush="#30808080" BorderThickness="1" CornerRadius="4" ClipToBounds="True">
                        <DockPanel>
                            <!-- Older commits are fetched a page at a time; this appears when the last
                                 load hit the limit, so the graph never has to build the whole repo up front. -->
                            <Button DockPanel.Dock="Bottom"
                                    Content="{loc:Tr History_LoadMore}"
                                    Command="{Binding LoadMoreCommitsCommand}"
                                    IsVisible="{Binding HasMoreCommits}"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Center"
                                    Margin="6" FontSize="12" />

                            <!-- Column headers — click to sort. HistoryHeaderMargin absorbs the graph
                                 gutter and the scrollbar so the labels line up with the rows below. -->
                            <Border DockPanel.Dock="Top" BorderBrush="#22808080" BorderThickness="0,0,0,1">
                                <Panel Height="24">
                                <Grid Margin="{Binding HistoryHeaderMargin}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" MinWidth="80" />
                                        <ColumnDefinition Width="{Binding AuthorColumnWidth}" />
                                        <ColumnDefinition Width="{Binding DateColumnWidth}" />
                                        <ColumnDefinition Width="{Binding CommitColumnWidth}" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Only Author and Date sort; Message and Commit are plain labels. -->
                                    <TextBlock Grid.Column="0" Text="{loc:Tr History_Col_Message}" Margin="4,0" VerticalAlignment="Center"
                                               FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource SubtleForeground}" />
                                    <Button Grid.Column="1" Classes="header"
                                            Content="{Binding AuthorSortGlyph, StringFormat='Author{0}'}"
                                            Command="{Binding SortByCommand}"
                                            CommandParameter="{x:Static vm:HistorySortColumn.Author}" />
                                    <Button Grid.Column="2" Classes="header"
                                            Content="{Binding DateSortGlyph, StringFormat='Date{0}'}"
                                            Command="{Binding SortByCommand}"
                                            CommandParameter="{x:Static vm:HistorySortColumn.Date}" />
                                    <TextBlock Grid.Column="3" Text="{loc:Tr History_Col_Commit}" Margin="4,0" VerticalAlignment="Center"
                                               FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource SubtleForeground}" />

                                    <!-- Drag a boundary to resize the two columns it separates; the
                                         header and every row share these widths. The Message|Author
                                         grip borrows from Message (the flexible column), so every
                                         column — Message and Commit included — is resizable. -->
                                    <Border Grid.Column="1" Tag="MsgAuthor" Classes="colgrip" Width="12" Margin="-6,0,0,0"
                                            HorizontalAlignment="Left" Background="Transparent" Cursor="SizeWestEast"
                                            PointerPressed="OnColumnGripPressed" PointerMoved="OnColumnGripMoved"
                                            PointerReleased="OnColumnGripReleased">
                                        <Border Width="1" HorizontalAlignment="Center" IsHitTestVisible="False"
                                                Background="{DynamicResource SubtleForeground}" Opacity="0.25" />
                                    </Border>
                                    <Border Grid.Column="2" Tag="AuthorDate" Classes="colgrip" Width="12" Margin="-6,0,0,0"
                                            HorizontalAlignment="Left" Background="Transparent" Cursor="SizeWestEast"
                                            PointerPressed="OnColumnGripPressed" PointerMoved="OnColumnGripMoved"
                                            PointerReleased="OnColumnGripReleased">
                                        <Border Width="1" HorizontalAlignment="Center" IsHitTestVisible="False"
                                                Background="{DynamicResource SubtleForeground}" Opacity="0.25" />
                                    </Border>
                                    <Border Grid.Column="3" Tag="DateCommit" Classes="colgrip" Width="12" Margin="-6,0,0,0"
                                            HorizontalAlignment="Left" Background="Transparent" Cursor="SizeWestEast"
                                            PointerPressed="OnColumnGripPressed" PointerMoved="OnColumnGripMoved"
                                            PointerReleased="OnColumnGripReleased">
                                        <Border Width="1" HorizontalAlignment="Center" IsHitTestVisible="False"
                                                Background="{DynamicResource SubtleForeground}" Opacity="0.25" />
                                    </Border>
                                </Grid>
                                <!-- Graph divider in the header, so the graph|Message boundary can be
                                     dragged from the header row too (not just down in the list). -->
                                <Border HorizontalAlignment="Left" VerticalAlignment="Stretch" Width="12"
                                        Classes="colgrip" Margin="{Binding GraphGripMargin}"
                                        Background="Transparent" Cursor="SizeWestEast"
                                        IsVisible="{Binding ShowGraph}"
                                        Tag="Graph"
                                        PointerPressed="OnGraphGripPressed" PointerMoved="OnGraphGripMoved"
                                        PointerReleased="OnGraphGripReleased">
                                    <Border Width="1" HorizontalAlignment="Center" IsHitTestVisible="False"
                                            Background="{DynamicResource SubtleForeground}" Opacity="0.25" />
                                </Border>
                                </Panel>
                            </Border>

                            <Panel>
                            <ListBox x:Name="CommitList"
                                     Background="Transparent"
                                     Padding="{Binding CommitListPadding}"
                                     ItemsSource="{Binding Commits}"
                                     SelectedItem="{Binding SelectedCommit}"
                                     DoubleTapped="OnCommitActivated">
                                <ListBox.ContextFlyout>
                                    <MenuFlyout>
                                        <MenuItem Header="{loc:Tr History_Ctx_AddTag}" Command="{Binding AddTagCommand}" />
                                        <MenuItem Header="{loc:Tr History_Ctx_CreateBranch}" Command="{Binding CreateBranchHereCommand}" />
                                        <Separator />
                                        <MenuItem Header="{loc:Tr History_Ctx_Checkout}"
                                                  Command="{Binding CheckoutCommitCommand}"
                                                  ToolTip.Tip="{loc:Tr History_Ctx_Checkout_Tooltip}" />
                                        <MenuItem Header="{loc:Tr History_Ctx_CherryPick}"
                                                  Command="{Binding CherryPickCommand}"
                                                  ToolTip.Tip="{loc:Tr History_Ctx_CherryPick_Tooltip}" />
                                        <MenuItem Header="{loc:Tr History_Ctx_Revert}" Command="{Binding RevertCommitCommand}" />
                                        <Separator />
                                        <MenuItem Header="{loc:Tr History_Ctx_Merge}" Command="{Binding MergeCommitCommand}" />
                                        <MenuItem Header="{loc:Tr History_Ctx_Rebase}" Command="{Binding RebaseOntoCommand}" />
                                        <MenuItem Header="{loc:Tr History_Ctx_Reset}" Command="{Binding ResetToCommitCommand}" />
                                        <Separator />
                                        <MenuItem Header="{loc:Tr History_Ctx_ViewMessage}" Click="OnViewCommitMessageClick" />
                                        <MenuItem Header="{loc:Tr History_Ctx_CopySha}" Click="OnCopyShaClick" />
                                        <MenuItem Header="{loc:Tr History_Ctx_CopySubject}" Click="OnCopySubjectClick" />
                                        <Separator />
                                        <MenuItem Header="{loc:Tr History_Ctx_OpenOnRemote}" Command="{Binding OpenCommitOnRemoteCommand}" />
                                        <MenuItem Header="{loc:Tr History_Ctx_CopyLink}" Command="{Binding CopyCommitLinkCommand}" />
                                        <Separator />
                                        <MenuItem Header="{loc:Tr History_Ctx_CompareWith}" Click="OnCompareCommitClick" />
                                    </MenuFlyout>
                                </ListBox.ContextFlyout>
                                <ListBox.Styles>
                                    <!-- Rows must be exactly as tall as the graph's row unit, or
                                         the lanes drift out of alignment with the dots. -->
                                    <Style Selector="ListBoxItem">
                                        <Setter Property="Height" Value="26" />
                                        <Setter Property="MinHeight" Value="26" />
                                        <Setter Property="Padding" Value="4,0" />
                                    </Style>
                                </ListBox.Styles>
                                <ListBox.ItemTemplate>
                                    <DataTemplate x:DataType="models:CommitInfo">
                                        <Grid VerticalAlignment="Center">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="{Binding $parent[ListBox].((vm:WorkspaceViewModel)DataContext).AuthorColumnWidth}" />
                                                <ColumnDefinition Width="{Binding $parent[ListBox].((vm:WorkspaceViewModel)DataContext).DateColumnWidth}" />
                                                <ColumnDefinition Width="{Binding $parent[ListBox].((vm:WorkspaceViewModel)DataContext).CommitColumnWidth}" />
                                            </Grid.ColumnDefinitions>
                                            <!-- Message column: ref badges then the subject. ClipToBounds keeps
                                                 long branch decorations from spilling into the Author column, and
                                                 the badge strip is capped so the subject always keeps some room. -->
                                            <Grid Grid.Column="0" ColumnDefinitions="Auto,*" ClipToBounds="True">
                                                <ItemsControl Grid.Column="0" ItemsSource="{Binding Refs}" Margin="0,0,6,0"
                                                              MaxWidth="240" ClipToBounds="True">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <StackPanel Orientation="Horizontal" Spacing="3" />
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate x:DataType="models:GitRef">
                                                            <Border Classes.tag="{Binding IsTag}"
                                                                    Classes.remote="{Binding IsRemoteBranch}"
                                                                    CornerRadius="3" Padding="4,1"
                                                                    MaxWidth="150" VerticalAlignment="Center"
                                                                    Cursor="Hand"
                                                                    DoubleTapped="OnRefBadgeDoubleTapped"
                                                                    ToolTip.Tip="{Binding Name, StringFormat='{}{0}  ·  double-click to check out, right-click for more'}">
                                                                <Border.ContextFlyout>
                                                                    <MenuFlyout>
                                                                        <MenuItem Header="{loc:Tr Ref_CheckOut}"
                                                                                  IsVisible="{Binding !IsTag}"
                                                                                  Click="OnCheckoutRefClick" />
                                                                        <MenuItem Header="{loc:Tr Ref_DeleteBranch}"
                                                                                  IsVisible="{Binding IsLocalBranch}"
                                                                                  Click="OnDeleteBranchClick" />
                                                                        <MenuItem Header="{loc:Tr Ref_OpenOnRemote}"
                                                                                  IsVisible="{Binding !IsTag}"
                                                                                  Click="OnOpenRefOnRemoteClick" />
                                                                    </MenuFlyout>
                                                                </Border.ContextFlyout>
                                                                <TextBlock Text="{Binding Name}" FontSize="10"
                                                                           Foreground="White"
                                                                           TextTrimming="CharacterEllipsis" />
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>

                                                <TextBlock Grid.Column="1" Text="{Binding Subject}"
                                                           TextTrimming="CharacterEllipsis" VerticalAlignment="Center">
                                                    <ToolTip.Tip>
                                                        <TextBlock x:DataType="models:CommitInfo"
                                                                   Text="{Binding Subject}"
                                                                   TextWrapping="Wrap" MaxWidth="520" />
                                                    </ToolTip.Tip>
                                                </TextBlock>
                                            </Grid>

                                            <TextBlock Grid.Column="1" Text="{Binding Author}"
                                                       Opacity="0.5" FontSize="11" Margin="0,0,8,0"
                                                       TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />

                                            <TextBlock Grid.Column="2" Text="{Binding WhenDisplay}"
                                                       Opacity="0.5" FontSize="11"
                                                       VerticalAlignment="Center" />

                                            <!-- Click-to-copy: copies the full SHA (the row still opens via the other columns). -->
                                            <Button Grid.Column="3" Classes="header"
                                                    Content="{Binding ShortSha}"
                                                    FontFamily="Cascadia Mono,Consolas,monospace"
                                                    FontWeight="Normal" Foreground="{DynamicResource FaintForeground}"
                                                    VerticalAlignment="Center"
                                                    Click="OnCopyShaCellClick"
                                                    ToolTip.Tip="{loc:Tr History_Sha_Tooltip}" />
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <views:CommitGraphView x:Name="GraphView"
                                                   Graph="{Binding Graph}"
                                                   Width="{Binding GraphGutter}"
                                                   IsVisible="{Binding ShowGraph}"
                                                   RowHeight="26"
                                                   HorizontalAlignment="Left"
                                                   VerticalAlignment="Stretch"
                                                   ClipToBounds="True"
                                                   IsHitTestVisible="False" />

                            <!-- Hit area over the lane graph: hover a commit's dot for its branch/HEAD
                                 popup (like GitKraken), click it to select the commit. -->
                            <Border HorizontalAlignment="Left" VerticalAlignment="Stretch"
                                    Width="{Binding GraphGutter}"
                                    IsVisible="{Binding ShowGraph}"
                                    Background="Transparent" Cursor="Hand"
                                    PointerMoved="OnGraphPointerMoved"
                                    PointerPressed="OnGraphPointerPressed"
                                    DoubleTapped="OnCommitActivated"
                                    ToolTip.Placement="Pointer"
                                    ToolTip.Tip="{Binding HoverInfo}" />

                            <!-- Draggable divider: sets how wide the graph gutter is. Narrower clips the
                                 graph (drag wider to see more lanes) and gives the message columns room. -->
                            <Border HorizontalAlignment="Left" Width="12" VerticalAlignment="Stretch"
                                    Classes="colgrip"
                                    Margin="{Binding GraphGripMargin}"
                                    Background="Transparent" Cursor="SizeWestEast"
                                    IsVisible="{Binding ShowGraph}"
                                    Tag="Graph"
                                    PointerPressed="OnGraphGripPressed"
                                    PointerMoved="OnGraphGripMoved"
                                    PointerReleased="OnGraphGripReleased"
                                    ToolTip.Tip="{loc:Tr History_GraphDivider_Tooltip}">
                                <Border Width="1" HorizontalAlignment="Center" IsHitTestVisible="False"
                                        Background="{DynamicResource SubtleForeground}" Opacity="0.25" />
                            </Border>

                            <!-- Full-height column dividers: the 24px header grips are a tiny target, so
                                 mirror them down the whole list — a boundary can be grabbed anywhere. The
                                 grid has no background, so only the 12px grips catch clicks; the rest of a
                                 row falls through to the list for selection. Columns/margin match the header
                                 so the grips line up with it and the rows. -->
                            <Grid Margin="{Binding HistoryHeaderMargin}" VerticalAlignment="Stretch"
                                  IsVisible="{Binding HasCommits}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="{Binding AuthorColumnWidth}" />
                                    <ColumnDefinition Width="{Binding DateColumnWidth}" />
                                    <ColumnDefinition Width="{Binding CommitColumnWidth}" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="1" Tag="MsgAuthor" Classes="colgrip" Width="12" Margin="-6,0,0,0"
                                        HorizontalAlignment="Left" VerticalAlignment="Stretch"
                                        Background="Transparent" Cursor="SizeWestEast"
                                        PointerPressed="OnColumnGripPressed" PointerMoved="OnColumnGripMoved"
                                        PointerReleased="OnColumnGripReleased">
                                    <Border Width="1" HorizontalAlignment="Center" IsHitTestVisible="False"
                                            Background="{DynamicResource SubtleForeground}" Opacity="0.25" />
                                </Border>
                                <Border Grid.Column="2" Tag="AuthorDate" Classes="colgrip" Width="12" Margin="-6,0,0,0"
                                        HorizontalAlignment="Left" VerticalAlignment="Stretch"
                                        Background="Transparent" Cursor="SizeWestEast"
                                        PointerPressed="OnColumnGripPressed" PointerMoved="OnColumnGripMoved"
                                        PointerReleased="OnColumnGripReleased">
                                    <Border Width="1" HorizontalAlignment="Center" IsHitTestVisible="False"
                                            Background="{DynamicResource SubtleForeground}" Opacity="0.25" />
                                </Border>
                                <Border Grid.Column="3" Tag="DateCommit" Classes="colgrip" Width="12" Margin="-6,0,0,0"
                                        HorizontalAlignment="Left" VerticalAlignment="Stretch"
                                        Background="Transparent" Cursor="SizeWestEast"
                                        PointerPressed="OnColumnGripPressed" PointerMoved="OnColumnGripMoved"
                                        PointerReleased="OnColumnGripReleased">
                                    <Border Width="1" HorizontalAlignment="Center" IsHitTestVisible="False"
                                            Background="{DynamicResource SubtleForeground}" Opacity="0.25" />
                                </Border>
                            </Grid>

                            <TextBlock Text="{loc:Tr History_NoCommits}"
                                       IsVisible="{Binding !HasCommits}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Opacity="0.35" IsHitTestVisible="False" />
                            </Panel>
                        </DockPanel>
                    </Border>
                </DockPanel>

                <!-- Diff viewer. History adds the selected commit's file list on top; the divider
                     between it and the diff is draggable. CommitFilesRow is collapsed to 0 in Changes
                     mode (and the splitter hidden) from code-behind, so Changes shows the diff full-height. -->
                <Grid Grid.Column="2" x:Name="DiffPaneGrid">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="150" MinHeight="60" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" MinHeight="80" />
                    </Grid.RowDefinitions>

                    <!-- History: the selected commit's files, split out so the diff is one file at a
                         time instead of one long blob. Picking a file loads just its patch. -->
                    <Border Grid.Row="0" IsVisible="{Binding IsHistoryMode}"
                            BorderBrush="#30808080" BorderThickness="1" CornerRadius="4"
                            ClipToBounds="True">
                        <DockPanel>
                            <!-- Branch/HEAD bar for the selected commit (loaded on select), with the
                                 pane's close button at its right end. The bar itself is always present in
                                 History so the ✕ never disappears when nothing is selected — only the
                                 commit info inside it waits for a selection. The ✕ lives here rather than
                                 floating over the file list, where it read as closing the first file. -->
                            <Border DockPanel.Dock="Top"
                                    Background="#22588CF0" BorderBrush="#40588CF0" BorderThickness="0,0,0,1" Padding="8,3">
                                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="6">
                                    <ContentControl Grid.Column="0" Content="{Binding SelectedInfo}"
                                                    HorizontalAlignment="Left" VerticalAlignment="Center"
                                                    IsVisible="{Binding SelectedInfo.HasSha}"
                                                    ContentTemplate="{StaticResource BranchInfoLine}" />
                                    <!-- Folder tree vs the flat full-path list. Deep repo paths are hard
                                         to scan flat; a shallow commit reads better flat. -->
                                    <!-- Icon only: the bar is deliberately one line, and a labelled
                                         button pushed the commit card onto a second row. -->
                                    <ToggleButton Grid.Column="1" Classes="header"
                                                  Content="🗀"
                                                  VerticalAlignment="Center" FontSize="12" Padding="6,1"
                                                  IsChecked="{Binding ShowFilesAsTree}"
                                                  IsVisible="{Binding HasCommitFiles}"
                                                  ToolTip.Tip="{loc:Tr Files_TreeView_Tooltip}" />
                                    <Button Grid.Column="2" Content="✕" Classes="header"
                                            VerticalAlignment="Center" FontSize="12" Padding="6,1"
                                            Click="OnHideDiffPaneClick"
                                            ToolTip.Tip="{loc:Tr History_HideDiff_Tooltip}" />
                                </Grid>
                            </Border>
                        <Panel>
                            <ListBox x:Name="CommitFilesList"
                                     Background="Transparent"
                                     IsVisible="{Binding !ShowFilesAsTree}"
                                     ItemsSource="{Binding CommitFiles}"
                                     SelectedItem="{Binding SelectedCommitFile}">
                                <ListBox.ContextFlyout>
                                    <MenuFlyout>
                                        <MenuItem Header="{loc:Tr Changes_OpenFile}" Click="OnOpenCommitFileClick" />
                                        <Separator />
                                        <MenuItem Header="{loc:Tr Changes_Blame}" Click="OnBlameCommitFileClick" />
                                        <MenuItem Header="{loc:Tr Changes_FileHistory}" Click="OnShowCommitFileHistoryClick" />
                                    </MenuFlyout>
                                </ListBox.ContextFlyout>
                                <ListBox.ItemTemplate>
                                    <DataTemplate x:DataType="models:CommitFileEntry">
                                        <Grid ColumnDefinitions="Auto,*">
                                            <TextBlock Grid.Column="0" Text="{Binding Badge}" Width="18"
                                                       FontWeight="SemiBold" FontFamily="Cascadia Mono,Consolas,monospace"
                                                       Foreground="{Binding Badge, Converter={StaticResource FileStatusBrush}}" />
                                            <TextBlock Grid.Column="1" Text="{Binding Path}" TextTrimming="CharacterEllipsis" />
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <!-- Same files as a folder tree. Runs of single-child folders are collapsed
                                 into one row by the builder, so deep paths don't become pure indentation. -->
                            <TreeView x:Name="CommitFilesTree"
                                      Background="Transparent"
                                      IsVisible="{Binding ShowFilesAsTree}"
                                      ItemsSource="{Binding CommitFileNodes}"
                                      SelectedItem="{Binding SelectedCommitFileNode}">
                                <TreeView.Styles>
                                    <!-- A commit touches few files, so expanded is the useful default;
                                         collapsed would mean clicking through folders every time. -->
                                    <Style Selector="TreeViewItem">
                                        <Setter Property="IsExpanded" Value="True" />
                                    </Style>
                                </TreeView.Styles>
                                <TreeView.ContextFlyout>
                                    <MenuFlyout>
                                        <MenuItem Header="{loc:Tr Changes_OpenFile}" Click="OnOpenCommitFileClick" />
                                        <Separator />
                                        <MenuItem Header="{loc:Tr Changes_Blame}" Click="OnBlameCommitFileClick" />
                                        <MenuItem Header="{loc:Tr Changes_FileHistory}" Click="OnShowCommitFileHistoryClick" />
                                    </MenuFlyout>
                                </TreeView.ContextFlyout>
                                <TreeView.ItemTemplate>
                                    <TreeDataTemplate x:DataType="vm:CommitFileNode" ItemsSource="{Binding Children}">
                                        <Grid ColumnDefinitions="Auto,*">
                                            <TextBlock Grid.Column="0" Text="{Binding Badge}" Width="18"
                                                       FontWeight="SemiBold" FontFamily="Cascadia Mono,Consolas,monospace"
                                                       Foreground="{Binding Badge, Converter={StaticResource FileStatusBrush}}" />
                                            <TextBlock Grid.Column="1" Text="{Binding Name}"
                                                       TextTrimming="CharacterEllipsis" />
                                        </Grid>
                                    </TreeDataTemplate>
                                </TreeView.ItemTemplate>
                            </TreeView>

                            <TextBlock Text="{loc:Tr Diff_NoFilesChanged}"
                                       IsVisible="{Binding !HasCommitFiles}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Opacity="0.35" IsHitTestVisible="False" />
                        </Panel>
                        </DockPanel>
                    </Border>

                    <!-- Draggable divider between the commit's files and the diff (History only). -->
                    <GridSplitter Grid.Row="1" Classes="hsplit" Height="10"
                                  ResizeDirection="Rows" ResizeBehavior="PreviousAndNext"
                                  IsVisible="{Binding IsHistoryMode}" />

                    <DockPanel Grid.Row="2">
                        <Grid DockPanel.Dock="Top" Margin="0,0,0,4" ColumnDefinitions="*,Auto,Auto"
                              ColumnSpacing="6"
                              IsVisible="{Binding HasDiff}">
                            <TextBlock Grid.Column="0"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"
                                       Text="{Binding DiffPath, StringFormat='Diff — {0}'}" />
                            <!-- Merges only: swap the "what this brought in" diff for the combined one,
                                 i.e. what was decided by hand while resolving — content that exists in
                                 no other commit and that a plain log never shows. -->
                            <ToggleButton Grid.Column="1" Classes="header"
                                          Content="{loc:Tr Diff_MergeResolution}"
                                          IsVisible="{Binding IsMergeCommitSelected}"
                                          IsChecked="{Binding ShowMergeResolution}"
                                          ToolTip.Tip="{loc:Tr Diff_MergeResolution_Tooltip}" />
                            <!-- Opens the diff in its own window: two aligned columns need real width,
                                 which this pane doesn't have. -->
                            <Button Grid.Column="2" Classes="header"
                                    Content="{loc:Tr Diff_SideBySide}"
                                    Click="OnCompareClick"
                                    ToolTip.Tip="{loc:Tr Diff_SideBySide_Tooltip}" />
                        </Grid>
                        <TextBlock DockPanel.Dock="Top"
                                   Margin="0,0,0,4"
                                   FontWeight="SemiBold"
                                   Opacity="0.6"
                                   Text="{loc:Tr Diff_Header}"
                                   IsVisible="{Binding !HasDiff}" />

                        <Border BorderBrush="#30808080" BorderThickness="1" CornerRadius="4" ClipToBounds="True">
                            <Panel>
                                <edit:TextEditor x:Name="DiffEditor"
                                                 IsReadOnly="True"
                                                 ShowLineNumbers="False"
                                                 FontFamily="Cascadia Mono,Consolas,Menlo,monospace"
                                                 FontSize="12"
                                                 Background="Transparent"
                                                 HorizontalScrollBarVisibility="Auto"
                                                 VerticalScrollBarVisibility="Auto"
                                                 IsVisible="{Binding HasDiff}" />

                                <TextBlock Text="{Binding DiffEmptyHint}"
                                           IsVisible="{Binding !HasDiff}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Opacity="0.35" IsHitTestVisible="False" />
                            </Panel>
                        </Border>
                    </DockPanel>
                </Grid>
            </Grid>

            <!-- Commit (staging only — History has nothing to commit) -->
            <TextBox Grid.Row="2"
                     Margin="0,12,0,0"
                     MinHeight="56"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     PlaceholderText="{loc:Tr Commit_MessagePlaceholder}"
                     Text="{Binding CommitMessage}"
                     IsVisible="{Binding !IsHistoryMode}"
                     IsEnabled="{Binding !IsBusy}" />

            <Grid Grid.Row="3" ColumnDefinitions="Auto,Auto,Auto,Auto,Auto,*,Auto" Margin="0,8,0,0"
                  IsVisible="{Binding !IsHistoryMode}">
                <!-- Commit (staged) plus a menu of the variants — amend, commit-all, sign-off, undo. -->
                <Button Grid.Column="0" Classes="success" Content="{loc:Tr Commit_Commit}"
                        Command="{Binding CommitCommand}" IsEnabled="{Binding CanCommit}" />
                <Button Grid.Column="1" Classes="success" Content="▾" Margin="3,0,0,0"
                        IsEnabled="{Binding !IsBusy}" ToolTip.Tip="{loc:Tr Commit_MoreOptions_Tooltip}">
                    <Button.Flyout>
                        <MenuFlyout Placement="Top">
                            <MenuItem Header="{loc:Tr Commit_CommitAll}" Command="{Binding CommitAllCommand}"
                                      ToolTip.Tip="{loc:Tr Commit_CommitAll_Tooltip}" />
                            <Separator />
                            <MenuItem Header="{loc:Tr Commit_Amend}" Command="{Binding CommitAmendCommand}"
                                      ToolTip.Tip="{loc:Tr Commit_Amend_Tooltip}" />
                            <MenuItem Header="{loc:Tr Commit_AllAmend}" Command="{Binding CommitAllAmendCommand}"
                                      ToolTip.Tip="{loc:Tr Commit_AllAmend_Tooltip}" />
                            <Separator />
                            <MenuItem Header="{loc:Tr Commit_SignedOff}" Command="{Binding CommitSignedOffCommand}"
                                      ToolTip.Tip="{loc:Tr Commit_SignedOff_Tooltip}" />
                            <Separator />
                            <MenuItem Header="{loc:Tr Commit_UndoLast}" Command="{Binding UndoLastCommitCommand}"
                                      ToolTip.Tip="{loc:Tr Commit_UndoLast_Tooltip}" />
                        </MenuFlyout>
                    </Button.Flyout>
                </Button>

                <!-- ✨ AI: draft the message from the staged diff using the local Ollama model. -->
                <Button Grid.Column="2" Content="{loc:Tr Commit_Generate}" Margin="8,0,0,0"
                        Command="{Binding GenerateCommitMessageCommand}" IsEnabled="{Binding HasStagedFiles}"
                        ToolTip.Tip="{loc:Tr Commit_Generate_Tooltip}" />

                <!-- ⚙ Commit template + AI settings, edited in a flyout and saved immediately. -->
                <Button Grid.Column="3" Content="⚙" Margin="4,0,0,0" ToolTip.Tip="{loc:Tr Commit_Settings_Tooltip}">
                    <Button.Flyout>
                        <Flyout Placement="Top">
                            <StackPanel Width="380" Spacing="8" x:DataType="vm:WorkspaceViewModel">
                                <TextBlock Text="{loc:Tr CommitSettings_TemplateHeader}" FontSize="10" Opacity="0.5" />
                                <TextBox AcceptsReturn="True" TextWrapping="Wrap" MinHeight="70"
                                         PlaceholderText="{loc:Tr CommitSettings_TemplatePlaceholder}"
                                         Text="{Binding CommitTemplate, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                                <Separator Margin="0,2" />

                                <TextBlock Text="{loc:Tr CommitSettings_AiEngineHeader}" FontSize="10" Opacity="0.5" />
                                <ComboBox HorizontalAlignment="Stretch" SelectedIndex="{Binding AiEngineIndex, Mode=TwoWay}">
                                    <ComboBoxItem Content="{loc:Tr CommitSettings_Engine_Builtin}" />
                                    <ComboBoxItem Content="{loc:Tr CommitSettings_Engine_Ollama}" />
                                </ComboBox>

                                <!-- Built-in engine: pick a model from the catalog, download once, done. -->
                                <StackPanel Spacing="8" IsVisible="{Binding UseBuiltinEngine}">
                                    <ComboBox HorizontalAlignment="Stretch"
                                              ItemsSource="{Binding BuiltinModels}"
                                              SelectedItem="{Binding SelectedBuiltinModel, Mode=TwoWay}">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate x:DataType="services:CommitModelPreset">
                                                <TextBlock Text="{Binding DisplayName}" />
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                        <TextBlock Grid.Column="0" Text="{Binding BuiltinModelStatus}"
                                                   FontSize="12" Opacity="0.7" VerticalAlignment="Center" />
                                        <Button Grid.Column="1" Classes="primary" Content="{loc:Tr CommitSettings_Download}" FontSize="12" Padding="10,3"
                                                IsVisible="{Binding NeedsModelDownload}"
                                                Command="{Binding DownloadModelCommand}" />
                                    </Grid>
                                    <ProgressBar Minimum="0" Maximum="100" Height="6"
                                                 Value="{Binding ModelDownloadProgress}"
                                                 IsVisible="{Binding IsDownloadingModel}" />
                                </StackPanel>

                                <!-- Ollama engine: point at an existing server. -->
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8" RowDefinitions="Auto,Auto" RowSpacing="6"
                                      IsVisible="{Binding UseOllamaEngine}">
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="{loc:Tr CommitSettings_Server}" FontSize="12" VerticalAlignment="Center" />
                                    <TextBox Grid.Row="0" Grid.Column="1" FontSize="12" Padding="6,3"
                                             Text="{Binding OllamaUrl, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="{loc:Tr CommitSettings_Model}" FontSize="12" VerticalAlignment="Center" />
                                    <TextBox Grid.Row="1" Grid.Column="1" FontSize="12" Padding="6,3"
                                             PlaceholderText="{loc:Tr CommitSettings_ModelPlaceholder}"
                                             Text="{Binding OllamaModel, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                                </Grid>

                                <TextBlock Text="{loc:Tr CommitSettings_LocalNote}"
                                           FontSize="10" Opacity="0.4" TextWrapping="Wrap" />
                            </StackPanel>
                        </Flyout>
                    </Button.Flyout>
                </Button>

                <TextBlock Grid.Column="4"
                           Text="{loc:Tr Status_WorkingTreeClean}"
                           IsVisible="{Binding IsCleanTree}"
                           Margin="12,0,0,0"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource GreenBrush}"
                           Opacity="0.8" />
                <TextBlock Grid.Column="5"
                           Text="{Binding StatusText}"
                           Margin="12,0,0,0"
                           VerticalAlignment="Center"
                           Opacity="0.7"
                           MaxLines="1"
                           TextTrimming="CharacterEllipsis"
                           ToolTip.Tip="{Binding StatusText}" />
                <!-- Discard all: destructive, so red and confirmed. -->
                <Button Grid.Column="6" Classes="danger" Content="{loc:Tr Status_DiscardAll}"
                        Command="{Binding DiscardAllCommand}" IsEnabled="{Binding !IsCleanTree}"
                        ToolTip.Tip="{loc:Tr Status_DiscardAll_Tooltip}" />
            </Grid>

            <Grid Grid.Row="4" Margin="0,10,0,0" ColumnDefinitions="Auto,*,Auto">
                <TextBlock Grid.Column="0"
                           Opacity="0.4"
                           FontSize="11"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           Text="{Binding FooterHint}" />

                <!-- Operation feedback (Pulled, errors, …) for History mode, where the commit
                     status bar is hidden. MaxLines=1 keeps git's multi-line output from growing
                     the row and breaking the layout; the full text is in the tooltip. -->
                <TextBlock Grid.Column="1"
                           IsVisible="{Binding IsHistoryMode}"
                           Margin="16,0"
                           Opacity="0.7"
                           FontSize="11"
                           VerticalAlignment="Center"
                           MaxLines="1"
                           TextTrimming="CharacterEllipsis"
                           Text="{Binding StatusText}"
                           ToolTip.Tip="{Binding StatusText}" />

                <!-- File-status legend: the same letters/colours shown beside each changed file,
                     so the code (green A, amber M, red D, blue R/C, orange U, grey ?) is on screen. -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="11" VerticalAlignment="Center"
                            ToolTip.Tip="{loc:Tr Legend_Tooltip}">
                    <StackPanel Orientation="Horizontal" Spacing="3">
                        <TextBlock Text="A" FontSize="11" FontWeight="SemiBold"
                                   FontFamily="Cascadia Mono,Consolas,monospace"
                                   Foreground="{DynamicResource FileStatusAddedBrush}" />
                        <TextBlock Text="{loc:Tr Legend_Added}" FontSize="11" Opacity="0.5" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="3">
                        <TextBlock Text="M" FontSize="11" FontWeight="SemiBold"
                                   FontFamily="Cascadia Mono,Consolas,monospace"
                                   Foreground="{DynamicResource FileStatusModifiedBrush}" />
                        <TextBlock Text="{loc:Tr Legend_Modified}" FontSize="11" Opacity="0.5" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="3">
                        <TextBlock Text="D" FontSize="11" FontWeight="SemiBold"
                                   FontFamily="Cascadia Mono,Consolas,monospace"
                                   Foreground="{DynamicResource FileStatusDeletedBrush}" />
                        <TextBlock Text="{loc:Tr Legend_Deleted}" FontSize="11" Opacity="0.5" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="3">
                        <TextBlock Text="R" FontSize="11" FontWeight="SemiBold"
                                   FontFamily="Cascadia Mono,Consolas,monospace"
                                   Foreground="{DynamicResource FileStatusMovedBrush}" />
                        <TextBlock Text="{loc:Tr Legend_Renamed}" FontSize="11" Opacity="0.5" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="3">
                        <TextBlock Text="U" FontSize="11" FontWeight="SemiBold"
                                   FontFamily="Cascadia Mono,Consolas,monospace"
                                   Foreground="{DynamicResource FileStatusConflictBrush}" />
                        <TextBlock Text="{loc:Tr Legend_Conflict}" FontSize="11" Opacity="0.5" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="3">
                        <TextBlock Text="?" FontSize="11" FontWeight="SemiBold"
                                   FontFamily="Cascadia Mono,Consolas,monospace"
                                   Foreground="{DynamicResource FileStatusNeutralBrush}" />
                        <TextBlock Text="{loc:Tr Legend_Untracked}" FontSize="11" Opacity="0.5" />
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Grid>
        </Panel>

        </Panel>

    </DockPanel>

</Window>
