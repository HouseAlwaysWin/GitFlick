<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:GitFlick.ViewModels"
        xmlns:models="using:GitFlick.Models"
        xmlns:views="using:GitFlick.Views"
        xmlns:edit="using:AvaloniaEdit"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1060" d:DesignHeight="660"
        x:Class="GitFlick.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Icon="/Assets/gitflick.ico"
        Title="GitFlick"
        Width="1060" Height="660"
        WindowStartupLocation="Manual"
        ShowInTaskbar="True">

    <Design.DataContext>
        <vm:MainViewModel />
    </Design.DataContext>

    <Window.Styles>
        <!-- Ref badges: local branch (default), remote, tag. -->
        <Style Selector="Border.tag, Border.remote">
            <Setter Property="Background" Value="#33808080" />
        </Style>
        <Style Selector="ItemsControl > ContentPresenter > Border">
            <Setter Property="Background" Value="#40F05133" />
        </Style>
        <Style Selector="ItemsControl > ContentPresenter > Border.remote">
            <Setter Property="Background" Value="#40588CF0" />
        </Style>
        <Style Selector="ItemsControl > ContentPresenter > Border.tag">
            <Setter Property="Background" Value="#403FB950" />
        </Style>
    </Window.Styles>

    <DockPanel Margin="16">

        <Border DockPanel.Dock="Top"
                IsVisible="{Binding HasHotkeyStatus}"
                Background="#40F05133"
                BorderBrush="#F05133"
                BorderThickness="1"
                CornerRadius="4"
                Padding="10,8"
                Margin="0,0,0,12">
            <TextBlock Text="{Binding HotkeyStatus}" TextWrapping="Wrap" />
        </Border>

        <Border DockPanel.Dock="Top"
                IsVisible="{Binding HasGitWarning}"
                Background="#40F05133"
                BorderBrush="#F05133"
                BorderThickness="1"
                CornerRadius="4"
                Padding="10,8"
                Margin="0,0,0,12">
            <TextBlock Text="{Binding GitWarning}" TextWrapping="Wrap" />
        </Border>

        <!-- Palette and workspace share the fill area; they're mutually exclusive via IsVisible.
             This wrapper fills as the DockPanel's last child so the palette can be centred within it. -->
        <Panel>

        <!-- Palette — centred command-palette card. -->
        <Grid IsVisible="{Binding IsPaletteVisible}"
              RowDefinitions="Auto,Auto,*,Auto"
              HorizontalAlignment="Center"
              MaxWidth="600">

            <Grid Grid.Row="0" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <TextBox Grid.Column="0"
                         x:Name="SearchBox"
                         PlaceholderText="Search pinned repositories…"
                         FontSize="16"
                         Padding="10,8"
                         Text="{Binding SearchText}" />
                <Button Grid.Column="1"
                        Classes="blue"
                        Content="Open…"
                        FontSize="14"
                        Padding="16,8"
                        VerticalAlignment="Stretch"
                        Click="OnOpenRepositoryClick"
                        ToolTip.Tip="Open a Git repository in a new workspace" />
            </Grid>

            <TextBlock Grid.Row="1"
                       IsVisible="{Binding HasStatusMessage}"
                       Text="{Binding StatusMessage}"
                       Foreground="#F05133"
                       Margin="2,8,0,0"
                       TextWrapping="Wrap" />

            <ListBox Grid.Row="2"
                     x:Name="RepoList"
                     Margin="0,12,0,0"
                     ItemsSource="{Binding Repos}"
                     SelectedItem="{Binding SelectedRepo}"
                     Background="Transparent"
                     BorderThickness="0">
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="models:RepositoryItem">
                        <StackPanel Spacing="1" Margin="0,2">
                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding Path}" Opacity="0.55" FontSize="11" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Empty states, mutually exclusive with the list having content -->
            <StackPanel Grid.Row="2"
                        IsVisible="{Binding !HasPinnedRepos}"
                        VerticalAlignment="Center"
                        Spacing="6">
                <TextBlock Text="No repositories pinned yet."
                           HorizontalAlignment="Center"
                           Opacity="0.7" />
                <TextBlock Text="Press Ctrl+O to pick a folder."
                           HorizontalAlignment="Center"
                           Opacity="0.45"
                           FontSize="12" />
            </StackPanel>

            <TextBlock Grid.Row="2"
                       IsVisible="{Binding HasNoMatches}"
                       Text="No matches."
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       Opacity="0.55" />

            <TextBlock Grid.Row="3"
                       Margin="2,10,0,0"
                       Opacity="0.4"
                       FontSize="11"
                       Text="↑↓ select · Enter / double-click open · Ctrl+O add · Ctrl+D remove · Esc close" />
        </Grid>

        <!-- Workspace. The outer Panel keeps IsVisible bound to MainViewModel; the inner Grid
             switches DataContext to the WorkspaceViewModel. -->
        <Panel IsVisible="{Binding IsRepoOpen}">
        <Grid DataContext="{Binding Workspace}"
              x:DataType="vm:WorkspaceViewModel"
              RowDefinitions="Auto,*,Auto,Auto,Auto">

            <!-- One clean toolbar row. Branch and stash operations live in categorised flyouts
                 rather than a second row of buttons. -->
            <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Button Content="← Back" Click="OnBackClick" VerticalAlignment="Center"
                            ToolTip.Tip="Back to repositories (Esc)" />
                    <TextBlock Text="{Binding Repository.Name}" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Border Background="#33808080" CornerRadius="3" Padding="6,2" VerticalAlignment="Center">
                        <TextBlock Text="{Binding BranchName}" FontSize="12" />
                    </Border>
                    <TextBlock VerticalAlignment="Center" Opacity="0.6" FontSize="12"
                               Text="{Binding Ahead, StringFormat='↑{0}'}"
                               IsVisible="{Binding Ahead}" />
                    <TextBlock VerticalAlignment="Center" Opacity="0.6" FontSize="12"
                               Text="{Binding Behind, StringFormat='↓{0}'}"
                               IsVisible="{Binding Behind}" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" IsEnabled="{Binding !IsBusy}">
                    <!-- The active view is the one wearing the accent. -->
                    <Button Content="Changes" Command="{Binding ShowChangesCommand}"
                            Classes.primary="{Binding !IsHistoryMode}" />
                    <Button Content="History" Command="{Binding ShowHistoryCommand}"
                            Classes.primary="{Binding IsHistoryMode}" />

                    <Rectangle Width="1" Margin="4,4" Fill="#33FFFFFF" />

                    <!-- Primary click runs the plain action; the chevron opens the variants,
                         mirroring VS Code's Pull/Fetch split menus. -->
                    <SplitButton Content="Fetch" Command="{Binding FetchCommand}"
                                 ToolTip.Tip="Fetch (⌄ for prune / all remotes)">
                        <SplitButton.Flyout>
                            <MenuFlyout Placement="BottomEdgeAlignedRight">
                                <MenuItem Header="Fetch (Prune)" Command="{Binding FetchPruneCommand}"
                                          ToolTip.Tip="Also drop remote-tracking branches deleted upstream" />
                                <MenuItem Header="Fetch From All Remotes" Command="{Binding FetchAllCommand}"
                                          ToolTip.Tip="Fetch from every configured remote" />
                            </MenuFlyout>
                        </SplitButton.Flyout>
                    </SplitButton>
                    <SplitButton Content="Pull" Command="{Binding PullCommand}"
                                 ToolTip.Tip="Pull (⌄ for rebase / from…)">
                        <SplitButton.Flyout>
                            <MenuFlyout Placement="BottomEdgeAlignedRight">
                                <MenuItem Header="Pull (Rebase)" Command="{Binding PullRebaseCommand}"
                                          ToolTip.Tip="Replay local commits on top of upstream instead of merging" />
                                <MenuItem Header="Pull from…" Command="{Binding PullFromCommand}"
                                          ToolTip.Tip="Pull a specific branch from a chosen remote" />
                            </MenuFlyout>
                        </SplitButton.Flyout>
                    </SplitButton>
                    <SplitButton Content="Push" Command="{Binding PushCommand}"
                                 ToolTip.Tip="Push (⌄ for push to…)">
                        <SplitButton.Flyout>
                            <MenuFlyout Placement="BottomEdgeAlignedRight">
                                <MenuItem Header="Push to…" Command="{Binding PushToCommand}"
                                          ToolTip.Tip="Push the current branch to a chosen remote" />
                            </MenuFlyout>
                        </SplitButton.Flyout>
                    </SplitButton>

                    <Button Content="Branch ▾">
                        <Button.Flyout>
                            <Flyout Placement="BottomEdgeAlignedRight">
                                <StackPanel Width="300" Spacing="8" x:DataType="vm:WorkspaceViewModel">
                                    <TextBlock Text="CREATE BRANCH" FontSize="10" Opacity="0.5" />
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
                                        <TextBox Grid.Column="0" PlaceholderText="new branch name"
                                                 Text="{Binding NewBranchName}" VerticalContentAlignment="Center" />
                                        <Button Grid.Column="1" Content="Create" Command="{Binding CreateBranchCommand}" />
                                    </Grid>

                                    <Separator Margin="0,4" />

                                    <TextBlock Text="BRANCHES" FontSize="10" Opacity="0.5" />
                                    <ListBox MaxHeight="200"
                                             ItemsSource="{Binding Branches}"
                                             SelectedItem="{Binding SelectedBranch}">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate x:DataType="models:GitBranch">
                                                <Grid ColumnDefinitions="*,Auto">
                                                    <TextBlock Grid.Column="0" Text="{Binding Name}" />
                                                    <TextBlock Grid.Column="1" Text="current" FontSize="10" Opacity="0.5"
                                                               IsVisible="{Binding IsCurrent}" />
                                                </Grid>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="6">
                                        <Button Grid.Column="0" Content="Checkout" HorizontalAlignment="Stretch"
                                                HorizontalContentAlignment="Center" Command="{Binding CheckoutCommand}" />
                                        <Button Grid.Column="1" Content="Merge" HorizontalAlignment="Stretch"
                                                HorizontalContentAlignment="Center" Command="{Binding MergeCommand}" />
                                        <Button Grid.Column="2" Content="Delete" HorizontalAlignment="Stretch"
                                                HorizontalContentAlignment="Center" Command="{Binding DeleteBranchCommand}" />
                                    </Grid>
                                    <TextBlock Text="Checkout / Merge / Delete act on the selected branch."
                                               FontSize="10" Opacity="0.4" TextWrapping="Wrap" />
                                </StackPanel>
                            </Flyout>
                        </Button.Flyout>
                    </Button>

                    <Button Content="Stash ▾">
                        <Button.Flyout>
                            <Flyout Placement="BottomEdgeAlignedRight">
                                <StackPanel Width="260" Spacing="8" x:DataType="vm:WorkspaceViewModel">
                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="6">
                                        <Button Grid.Column="0" Content="Stash changes" HorizontalAlignment="Stretch"
                                                HorizontalContentAlignment="Center" Command="{Binding StashPushCommand}" />
                                        <Button Grid.Column="1" Content="Pop latest" HorizontalAlignment="Stretch"
                                                HorizontalContentAlignment="Center" Command="{Binding StashPopCommand}" />
                                    </Grid>
                                    <Separator Margin="0,4" />
                                    <TextBlock Text="STASHES" FontSize="10" Opacity="0.5" />
                                    <ListBox MaxHeight="160" ItemsSource="{Binding Stashes}">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate x:DataType="models:StashEntry">
                                                <TextBlock Text="{Binding Description}" TextTrimming="CharacterEllipsis" />
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                    <TextBlock Text="No stashes" IsVisible="{Binding !HasStashes}" Opacity="0.4" />
                                </StackPanel>
                            </Flyout>
                        </Button.Flyout>
                    </Button>

                    <Button Content="⟳" Command="{Binding RefreshCommand}" ToolTip.Tip="Refresh" />
                </StackPanel>
            </Grid>

            <!-- Left pane: file lists (Changes) or the commit graph (History). Right pane: diff.
                 The splitter owns the width from here on — deliberately not bound to the view
                 model, so switching modes never overrides where the user dragged it. -->
            <Grid Grid.Row="1" Margin="0,14,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="480" MinWidth="240" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="*" MinWidth="280" />
                </Grid.ColumnDefinitions>

                <GridSplitter Grid.Column="1"
                              ResizeDirection="Columns"
                              Background="Transparent"
                              ResizeBehavior="PreviousAndNext" />

                <Grid Grid.Column="0" RowDefinitions="*,10,*" IsVisible="{Binding !IsHistoryMode}">

                    <DockPanel Grid.Row="0">
                        <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,4">
                            <TextBlock Grid.Column="0" Text="Unstaged" FontWeight="SemiBold" VerticalAlignment="Center" />
                            <Button Grid.Column="1" Content="Stage all" FontSize="11"
                                    Command="{Binding StageAllCommand}" IsEnabled="{Binding !IsBusy}" />
                        </Grid>
                        <Border BorderBrush="#30808080" BorderThickness="1" CornerRadius="4">
                            <Panel>
                                <ListBox x:Name="UnstagedList"
                                         Background="Transparent"
                                         SelectionMode="Multiple"
                                         ItemsSource="{Binding UnstagedFiles}"
                                         SelectedItem="{Binding SelectedUnstagedFile}">
                                    <ListBox.ContextFlyout>
                                        <MenuFlyout>
                                            <MenuItem Header="Stage selected" Click="OnStageSelectedClick" />
                                        </MenuFlyout>
                                    </ListBox.ContextFlyout>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate x:DataType="models:GitStatusEntry">
                                            <TextBlock Text="{Binding Path}" TextTrimming="CharacterEllipsis" />
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                <TextBlock Text="No unstaged changes"
                                           IsVisible="{Binding !HasUnstagedFiles}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Opacity="0.35" IsHitTestVisible="False" />
                            </Panel>
                        </Border>
                    </DockPanel>

                    <DockPanel Grid.Row="2">
                        <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,4">
                            <TextBlock Grid.Column="0" Text="Staged" FontWeight="SemiBold" VerticalAlignment="Center" />
                            <Button Grid.Column="1" Content="Unstage all" FontSize="11"
                                    Command="{Binding UnstageAllCommand}" IsEnabled="{Binding !IsBusy}" />
                        </Grid>
                        <Border BorderBrush="#30808080" BorderThickness="1" CornerRadius="4">
                            <Panel>
                                <ListBox x:Name="StagedList"
                                         Background="Transparent"
                                         SelectionMode="Multiple"
                                         ItemsSource="{Binding StagedFiles}"
                                         SelectedItem="{Binding SelectedStagedFile}">
                                    <ListBox.ContextFlyout>
                                        <MenuFlyout>
                                            <MenuItem Header="Unstage selected" Click="OnUnstageSelectedClick" />
                                        </MenuFlyout>
                                    </ListBox.ContextFlyout>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate x:DataType="models:GitStatusEntry">
                                            <TextBlock Text="{Binding Path}" TextTrimming="CharacterEllipsis" />
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                <TextBlock Text="Nothing staged"
                                           IsVisible="{Binding !HasStagedFiles}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Opacity="0.35" IsHitTestVisible="False" />
                            </Panel>
                        </Border>
                    </DockPanel>
                </Grid>

                <!-- History: commit list with the lane graph drawn over its left gutter. -->
                <DockPanel Grid.Column="0" IsVisible="{Binding IsHistoryMode}">
                    <Grid DockPanel.Dock="Top" ColumnDefinitions="Auto,*,Auto" Margin="0,0,0,4">
                        <TextBlock Grid.Column="0" Text="History" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1" Text="{Binding StatusText}"
                                   Margin="12,0" VerticalAlignment="Center"
                                   Opacity="0.7" FontSize="11" TextTrimming="CharacterEllipsis" />
                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                            <Button Classes="header" FontWeight="Normal"
                                    Content="{Binding AuthorFilterLabel}"
                                    ToolTip.Tip="Show only commits by the ticked authors (multi-select).">
                                <Button.Flyout>
                                    <Flyout Placement="BottomEdgeAlignedRight">
                                        <StackPanel Width="250" Spacing="6" x:DataType="vm:WorkspaceViewModel">
                                            <Grid ColumnDefinitions="*,Auto">
                                                <TextBlock Grid.Column="0" Text="SHOW ONLY THESE AUTHORS"
                                                           FontSize="10" Opacity="0.5" VerticalAlignment="Center" />
                                                <Button Grid.Column="1" Content="Clear" FontSize="11" Padding="8,2"
                                                        IsEnabled="{Binding HasAuthorFilter}"
                                                        Command="{Binding ClearAuthorFilterCommand}" />
                                            </Grid>
                                            <TextBox Text="{Binding AuthorFilterSearch}" PlaceholderText="Search authors…"
                                                     FontSize="12" Padding="6,3" />
                                            <ScrollViewer MaxHeight="280">
                                                <ItemsControl ItemsSource="{Binding FilteredAuthorFilters}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate x:DataType="vm:FilterOption">
                                                            <CheckBox Content="{Binding Name}"
                                                                      IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                                      Margin="0,1" />
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </ScrollViewer>
                                        </StackPanel>
                                    </Flyout>
                                </Button.Flyout>
                            </Button>
                            <Button Classes="header" FontWeight="Normal"
                                    Content="{Binding BranchFilterLabel}"
                                    ToolTip.Tip="Show only commits reachable from the ticked branches (multi-select).">
                                <Button.Flyout>
                                    <Flyout Placement="BottomEdgeAlignedRight">
                                        <StackPanel Width="270" Spacing="6" x:DataType="vm:WorkspaceViewModel">
                                            <Grid ColumnDefinitions="*,Auto">
                                                <TextBlock Grid.Column="0" Text="SHOW ONLY THESE BRANCHES"
                                                           FontSize="10" Opacity="0.5" VerticalAlignment="Center" />
                                                <Button Grid.Column="1" Content="Clear" FontSize="11" Padding="8,2"
                                                        IsEnabled="{Binding HasBranchFilter}"
                                                        Command="{Binding ClearBranchFilterCommand}" />
                                            </Grid>
                                            <TextBox Text="{Binding BranchFilterSearch}" PlaceholderText="Search branches…"
                                                     FontSize="12" Padding="6,3" />
                                            <ScrollViewer MaxHeight="280">
                                                <ItemsControl ItemsSource="{Binding FilteredBranchFilters}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate x:DataType="vm:FilterOption">
                                                            <CheckBox Content="{Binding Name}"
                                                                      IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                                      Margin="0,1" />
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </ScrollViewer>
                                        </StackPanel>
                                    </Flyout>
                                </Button.Flyout>
                            </Button>
                            <Button Classes="header"
                                    Content="↕ Graph order"
                                    IsVisible="{Binding !ShowGraph}"
                                    Command="{Binding ResetSortCommand}"
                                    ToolTip.Tip="Drop the sort/filter and return to git's order (which shows the lane graph)." />
                            <CheckBox Content="First-parent only"
                                      FontSize="11"
                                      IsChecked="{Binding FirstParentOnly}"
                                      ToolTip.Tip="Collapse each merged branch to a single row — what actually landed on this branch." />
                        </StackPanel>
                    </Grid>

                    <Border BorderBrush="#30808080" BorderThickness="1" CornerRadius="4" ClipToBounds="True">
                        <DockPanel>
                            <!-- Column headers — click to sort. HistoryHeaderMargin absorbs the graph
                                 gutter and the scrollbar so the labels line up with the rows below. -->
                            <Border DockPanel.Dock="Top" BorderBrush="#22808080" BorderThickness="0,0,0,1">
                                <Grid Height="24" Margin="{Binding HistoryHeaderMargin}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" MinWidth="80" />
                                        <ColumnDefinition Width="{Binding AuthorColumnWidth}" />
                                        <ColumnDefinition Width="{Binding DateColumnWidth}" />
                                        <ColumnDefinition Width="{Binding CommitColumnWidth}" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Only Author and Date sort; Message and Commit are plain labels. -->
                                    <TextBlock Grid.Column="0" Text="Message" Margin="4,0" VerticalAlignment="Center"
                                               FontSize="11" FontWeight="SemiBold" Foreground="#B0FFFFFF" />
                                    <Button Grid.Column="1" Classes="header"
                                            Content="{Binding AuthorSortGlyph, StringFormat='Author{0}'}"
                                            Command="{Binding SortByCommand}"
                                            CommandParameter="{x:Static vm:HistorySortColumn.Author}" />
                                    <Button Grid.Column="2" Classes="header"
                                            Content="{Binding DateSortGlyph, StringFormat='Date{0}'}"
                                            Command="{Binding SortByCommand}"
                                            CommandParameter="{x:Static vm:HistorySortColumn.Date}" />
                                    <TextBlock Grid.Column="3" Text="Commit" Margin="4,0" VerticalAlignment="Center"
                                               FontSize="11" FontWeight="SemiBold" Foreground="#B0FFFFFF" />

                                    <!-- Drag a boundary to resize the two columns it separates; the
                                         header and every row share these widths. The Message|Author
                                         grip borrows from Message (the flexible column), so every
                                         column — Message and Commit included — is resizable. -->
                                    <Border Grid.Column="1" Tag="MsgAuthor" Width="8" HorizontalAlignment="Left"
                                            Background="Transparent" Cursor="SizeWestEast"
                                            PointerPressed="OnColumnGripPressed" PointerMoved="OnColumnGripMoved"
                                            PointerReleased="OnColumnGripReleased" />
                                    <Border Grid.Column="2" Tag="AuthorDate" Width="8" HorizontalAlignment="Left"
                                            Background="Transparent" Cursor="SizeWestEast"
                                            PointerPressed="OnColumnGripPressed" PointerMoved="OnColumnGripMoved"
                                            PointerReleased="OnColumnGripReleased" />
                                    <Border Grid.Column="3" Tag="DateCommit" Width="8" HorizontalAlignment="Left"
                                            Background="Transparent" Cursor="SizeWestEast"
                                            PointerPressed="OnColumnGripPressed" PointerMoved="OnColumnGripMoved"
                                            PointerReleased="OnColumnGripReleased" />
                                </Grid>
                            </Border>

                            <Panel>
                            <ListBox x:Name="CommitList"
                                     Background="Transparent"
                                     Padding="{Binding CommitListPadding}"
                                     ItemsSource="{Binding Commits}"
                                     SelectedItem="{Binding SelectedCommit}">
                                <ListBox.ContextFlyout>
                                    <MenuFlyout>
                                        <MenuItem Header="Checkout"
                                                  Command="{Binding CheckoutCommitCommand}"
                                                  ToolTip.Tip="Checks out the branch on this commit, or the commit itself (detached HEAD)." />
                                        <MenuItem Header="Cherry-pick"
                                                  Command="{Binding CherryPickCommand}"
                                                  ToolTip.Tip="Replay this commit on top of the current branch." />
                                        <Separator />
                                        <MenuItem Header="Copy full SHA" Click="OnCopyShaClick" />
                                    </MenuFlyout>
                                </ListBox.ContextFlyout>
                                <ListBox.Styles>
                                    <!-- Rows must be exactly as tall as the graph's row unit, or
                                         the lanes drift out of alignment with the dots. -->
                                    <Style Selector="ListBoxItem">
                                        <Setter Property="Height" Value="26" />
                                        <Setter Property="MinHeight" Value="26" />
                                        <Setter Property="Padding" Value="4,0" />
                                    </Style>
                                </ListBox.Styles>
                                <ListBox.ItemTemplate>
                                    <DataTemplate x:DataType="models:CommitInfo">
                                        <Grid VerticalAlignment="Center">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="{Binding $parent[ListBox].((vm:WorkspaceViewModel)DataContext).AuthorColumnWidth}" />
                                                <ColumnDefinition Width="{Binding $parent[ListBox].((vm:WorkspaceViewModel)DataContext).DateColumnWidth}" />
                                                <ColumnDefinition Width="{Binding $parent[ListBox].((vm:WorkspaceViewModel)DataContext).CommitColumnWidth}" />
                                            </Grid.ColumnDefinitions>
                                            <!-- Message column: ref badges then the subject. ClipToBounds keeps
                                                 long branch decorations from spilling into the Author column, and
                                                 the badge strip is capped so the subject always keeps some room. -->
                                            <Grid Grid.Column="0" ColumnDefinitions="Auto,*" ClipToBounds="True">
                                                <ItemsControl Grid.Column="0" ItemsSource="{Binding Refs}" Margin="0,0,6,0"
                                                              MaxWidth="240" ClipToBounds="True">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <StackPanel Orientation="Horizontal" Spacing="3" />
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate x:DataType="models:GitRef">
                                                            <Border Classes.tag="{Binding IsTag}"
                                                                    Classes.remote="{Binding IsRemoteBranch}"
                                                                    CornerRadius="3" Padding="4,1"
                                                                    MaxWidth="150" VerticalAlignment="Center"
                                                                    Cursor="Hand"
                                                                    DoubleTapped="OnRefBadgeDoubleTapped"
                                                                    ToolTip.Tip="{Binding Name, StringFormat='{}{0}  ·  double-click to check out, right-click for more'}">
                                                                <Border.ContextFlyout>
                                                                    <MenuFlyout>
                                                                        <MenuItem Header="Check out"
                                                                                  IsVisible="{Binding !IsTag}"
                                                                                  Click="OnCheckoutRefClick" />
                                                                        <MenuItem Header="Delete branch"
                                                                                  IsVisible="{Binding IsLocalBranch}"
                                                                                  Click="OnDeleteBranchClick" />
                                                                    </MenuFlyout>
                                                                </Border.ContextFlyout>
                                                                <TextBlock Text="{Binding Name}" FontSize="10"
                                                                           TextTrimming="CharacterEllipsis" />
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>

                                                <TextBlock Grid.Column="1" Text="{Binding Subject}"
                                                           TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                            </Grid>

                                            <TextBlock Grid.Column="1" Text="{Binding Author}"
                                                       Opacity="0.5" FontSize="11" Margin="0,0,8,0"
                                                       TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />

                                            <TextBlock Grid.Column="2" Text="{Binding WhenDisplay}"
                                                       Opacity="0.5" FontSize="11"
                                                       VerticalAlignment="Center" />

                                            <!-- Click-to-copy: copies the full SHA (the row still opens via the other columns). -->
                                            <Button Grid.Column="3" Classes="header"
                                                    Content="{Binding ShortSha}"
                                                    FontFamily="Cascadia Mono,Consolas,monospace"
                                                    FontWeight="Normal" Foreground="#8CFFFFFF"
                                                    VerticalAlignment="Center"
                                                    Click="OnCopyShaCellClick"
                                                    ToolTip.Tip="Click to copy the full SHA" />
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <views:CommitGraphView x:Name="GraphView"
                                                   Graph="{Binding Graph}"
                                                   Width="{Binding GraphWidth}"
                                                   IsVisible="{Binding ShowGraph}"
                                                   RowHeight="26"
                                                   HorizontalAlignment="Left"
                                                   VerticalAlignment="Stretch"
                                                   IsHitTestVisible="False" />

                            <TextBlock Text="No commits yet."
                                       IsVisible="{Binding !HasCommits}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Opacity="0.35" IsHitTestVisible="False" />
                            </Panel>
                        </DockPanel>
                    </Border>
                </DockPanel>

                <!-- Diff viewer -->
                <DockPanel Grid.Column="2">
                    <!-- History: the selected commit's files, split out so the diff is one file at a
                         time instead of one long blob. Picking a file loads just its patch. -->
                    <Border DockPanel.Dock="Top" IsVisible="{Binding IsHistoryMode}"
                            BorderBrush="#30808080" BorderThickness="1" CornerRadius="4"
                            Height="150" Margin="0,0,0,8" ClipToBounds="True">
                        <Panel>
                            <ListBox x:Name="CommitFilesList"
                                     Background="Transparent"
                                     ItemsSource="{Binding CommitFiles}"
                                     SelectedItem="{Binding SelectedCommitFile}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate x:DataType="models:CommitFileEntry">
                                        <Grid ColumnDefinitions="Auto,*">
                                            <TextBlock Grid.Column="0" Text="{Binding Badge}" Width="18"
                                                       Opacity="0.55" FontFamily="Cascadia Mono,Consolas,monospace" />
                                            <TextBlock Grid.Column="1" Text="{Binding Path}" TextTrimming="CharacterEllipsis" />
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <TextBlock Text="No files changed"
                                       IsVisible="{Binding !HasCommitFiles}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Opacity="0.35" IsHitTestVisible="False" />
                        </Panel>
                    </Border>

                    <TextBlock DockPanel.Dock="Top"
                               Margin="0,0,0,4"
                               FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis"
                               Text="{Binding DiffPath, StringFormat='Diff — {0}'}"
                               IsVisible="{Binding HasDiff}" />
                    <TextBlock DockPanel.Dock="Top"
                               Margin="0,0,0,4"
                               FontWeight="SemiBold"
                               Opacity="0.6"
                               Text="Diff"
                               IsVisible="{Binding !HasDiff}" />

                    <Border BorderBrush="#30808080" BorderThickness="1" CornerRadius="4" ClipToBounds="True">
                        <Panel>
                            <edit:TextEditor x:Name="DiffEditor"
                                             IsReadOnly="True"
                                             ShowLineNumbers="False"
                                             FontFamily="Cascadia Mono,Consolas,Menlo,monospace"
                                             FontSize="12"
                                             Background="Transparent"
                                             HorizontalScrollBarVisibility="Auto"
                                             VerticalScrollBarVisibility="Auto"
                                             IsVisible="{Binding HasDiff}" />
                            <TextBlock Text="{Binding DiffEmptyHint}"
                                       IsVisible="{Binding !HasDiff}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Opacity="0.35" IsHitTestVisible="False" />
                        </Panel>
                    </Border>
                </DockPanel>
            </Grid>

            <!-- Commit (staging only — History has nothing to commit) -->
            <TextBox Grid.Row="2"
                     Margin="0,12,0,0"
                     MinHeight="56"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     PlaceholderText="Commit message"
                     Text="{Binding CommitMessage}"
                     IsVisible="{Binding !IsHistoryMode}"
                     IsEnabled="{Binding !IsBusy}" />

            <Grid Grid.Row="3" ColumnDefinitions="Auto,Auto,*" Margin="0,8,0,0"
                  IsVisible="{Binding !IsHistoryMode}">
                <Button Grid.Column="0" Classes="primary" Content="Commit" Command="{Binding CommitCommand}" IsEnabled="{Binding CanCommit}" />
                <TextBlock Grid.Column="1"
                           Text="✓ Working tree clean"
                           IsVisible="{Binding IsCleanTree}"
                           Margin="12,0,0,0"
                           VerticalAlignment="Center"
                           Foreground="#4CAF50"
                           Opacity="0.8" />
                <TextBlock Grid.Column="2"
                           Text="{Binding StatusText}"
                           Margin="12,0,0,0"
                           VerticalAlignment="Center"
                           Opacity="0.7"
                           TextTrimming="CharacterEllipsis" />
            </Grid>

            <TextBlock Grid.Row="4"
                       Margin="0,10,0,0"
                       Opacity="0.4"
                       FontSize="11"
                       Text="{Binding FooterHint}" />
        </Grid>
        </Panel>

        </Panel>

    </DockPanel>

</Window>
