<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:GitFlick.ViewModels"
        xmlns:models="using:GitFlick.Models"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="780" d:DesignHeight="600"
        x:Class="GitFlick.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Icon="/Assets/gitflick.ico"
        Title="GitFlick"
        Width="780" Height="600"
        WindowStartupLocation="Manual"
        ShowInTaskbar="False">

    <Design.DataContext>
        <vm:MainViewModel />
    </Design.DataContext>

    <DockPanel Margin="16">

        <Border DockPanel.Dock="Top"
                IsVisible="{Binding HasHotkeyStatus}"
                Background="#40F05133"
                BorderBrush="#F05133"
                BorderThickness="1"
                CornerRadius="4"
                Padding="10,8"
                Margin="0,0,0,12">
            <TextBlock Text="{Binding HotkeyStatus}" TextWrapping="Wrap" />
        </Border>

        <Border DockPanel.Dock="Top"
                IsVisible="{Binding HasGitWarning}"
                Background="#40F05133"
                BorderBrush="#F05133"
                BorderThickness="1"
                CornerRadius="4"
                Padding="10,8"
                Margin="0,0,0,12">
            <TextBlock Text="{Binding GitWarning}" TextWrapping="Wrap" />
        </Border>

        <!-- Palette -->
        <Grid IsVisible="{Binding IsPaletteVisible}" RowDefinitions="Auto,Auto,*,Auto">

            <TextBox Grid.Row="0"
                     x:Name="SearchBox"
                     PlaceholderText="Search pinned repositories…"
                     FontSize="16"
                     Padding="10,8"
                     Text="{Binding SearchText}" />

            <TextBlock Grid.Row="1"
                       IsVisible="{Binding HasStatusMessage}"
                       Text="{Binding StatusMessage}"
                       Foreground="#F05133"
                       Margin="2,8,0,0"
                       TextWrapping="Wrap" />

            <ListBox Grid.Row="2"
                     x:Name="RepoList"
                     Margin="0,12,0,0"
                     ItemsSource="{Binding Repos}"
                     SelectedItem="{Binding SelectedRepo}"
                     Background="Transparent"
                     BorderThickness="0">
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="models:RepositoryItem">
                        <StackPanel Spacing="1" Margin="0,2">
                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding Path}" Opacity="0.55" FontSize="11" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Empty states, mutually exclusive with the list having content -->
            <StackPanel Grid.Row="2"
                        IsVisible="{Binding !HasPinnedRepos}"
                        VerticalAlignment="Center"
                        Spacing="6">
                <TextBlock Text="No repositories pinned yet."
                           HorizontalAlignment="Center"
                           Opacity="0.7" />
                <TextBlock Text="Press Ctrl+O to pick a folder."
                           HorizontalAlignment="Center"
                           Opacity="0.45"
                           FontSize="12" />
            </StackPanel>

            <TextBlock Grid.Row="2"
                       IsVisible="{Binding HasNoMatches}"
                       Text="No matches."
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       Opacity="0.55" />

            <TextBlock Grid.Row="3"
                       Margin="2,10,0,0"
                       Opacity="0.4"
                       FontSize="11"
                       Text="↑↓ select · Enter / double-click open · Ctrl+O add · Ctrl+D remove · Esc close" />
        </Grid>

        <!-- Workspace. The outer Panel keeps IsVisible bound to MainViewModel; the inner Grid
             switches DataContext to the WorkspaceViewModel. -->
        <Panel IsVisible="{Binding IsRepoOpen}">
        <Grid DataContext="{Binding Workspace}"
              x:DataType="vm:WorkspaceViewModel"
              RowDefinitions="Auto,*,Auto,Auto,Auto">

            <!-- One clean toolbar row. Branch and stash operations live in categorised flyouts
                 rather than a second row of buttons. -->
            <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Button Content="← Back" Click="OnBackClick" VerticalAlignment="Center"
                            ToolTip.Tip="Back to repositories (Esc)" />
                    <TextBlock Text="{Binding Repository.Name}" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Border Background="#33808080" CornerRadius="3" Padding="6,2" VerticalAlignment="Center">
                        <TextBlock Text="{Binding BranchName}" FontSize="12" />
                    </Border>
                    <TextBlock VerticalAlignment="Center" Opacity="0.6" FontSize="12"
                               Text="{Binding Ahead, StringFormat='↑{0}'}"
                               IsVisible="{Binding Ahead}" />
                    <TextBlock VerticalAlignment="Center" Opacity="0.6" FontSize="12"
                               Text="{Binding Behind, StringFormat='↓{0}'}"
                               IsVisible="{Binding Behind}" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" IsEnabled="{Binding !IsBusy}">
                    <Button Content="Fetch" Command="{Binding FetchCommand}" />
                    <Button Content="Pull" Command="{Binding PullCommand}" />
                    <Button Content="Push" Command="{Binding PushCommand}" />

                    <Button Content="Branch ▾">
                        <Button.Flyout>
                            <Flyout Placement="BottomEdgeAlignedRight">
                                <StackPanel Width="300" Spacing="8" x:DataType="vm:WorkspaceViewModel">
                                    <TextBlock Text="CREATE BRANCH" FontSize="10" Opacity="0.5" />
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
                                        <TextBox Grid.Column="0" PlaceholderText="new branch name"
                                                 Text="{Binding NewBranchName}" VerticalContentAlignment="Center" />
                                        <Button Grid.Column="1" Content="Create" Command="{Binding CreateBranchCommand}" />
                                    </Grid>

                                    <Separator Margin="0,4" />

                                    <TextBlock Text="BRANCHES" FontSize="10" Opacity="0.5" />
                                    <ListBox MaxHeight="200"
                                             ItemsSource="{Binding Branches}"
                                             SelectedItem="{Binding SelectedBranch}">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate x:DataType="models:GitBranch">
                                                <Grid ColumnDefinitions="*,Auto">
                                                    <TextBlock Grid.Column="0" Text="{Binding Name}" />
                                                    <TextBlock Grid.Column="1" Text="current" FontSize="10" Opacity="0.5"
                                                               IsVisible="{Binding IsCurrent}" />
                                                </Grid>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="6">
                                        <Button Grid.Column="0" Content="Checkout" HorizontalAlignment="Stretch"
                                                HorizontalContentAlignment="Center" Command="{Binding CheckoutCommand}" />
                                        <Button Grid.Column="1" Content="Merge" HorizontalAlignment="Stretch"
                                                HorizontalContentAlignment="Center" Command="{Binding MergeCommand}" />
                                        <Button Grid.Column="2" Content="Delete" HorizontalAlignment="Stretch"
                                                HorizontalContentAlignment="Center" Command="{Binding DeleteBranchCommand}" />
                                    </Grid>
                                    <TextBlock Text="Checkout / Merge / Delete act on the selected branch."
                                               FontSize="10" Opacity="0.4" TextWrapping="Wrap" />
                                </StackPanel>
                            </Flyout>
                        </Button.Flyout>
                    </Button>

                    <Button Content="Stash ▾">
                        <Button.Flyout>
                            <Flyout Placement="BottomEdgeAlignedRight">
                                <StackPanel Width="260" Spacing="8" x:DataType="vm:WorkspaceViewModel">
                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="6">
                                        <Button Grid.Column="0" Content="Stash changes" HorizontalAlignment="Stretch"
                                                HorizontalContentAlignment="Center" Command="{Binding StashPushCommand}" />
                                        <Button Grid.Column="1" Content="Pop latest" HorizontalAlignment="Stretch"
                                                HorizontalContentAlignment="Center" Command="{Binding StashPopCommand}" />
                                    </Grid>
                                    <Separator Margin="0,4" />
                                    <TextBlock Text="STASHES" FontSize="10" Opacity="0.5" />
                                    <ListBox MaxHeight="160" ItemsSource="{Binding Stashes}">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate x:DataType="models:StashEntry">
                                                <TextBlock Text="{Binding Description}" TextTrimming="CharacterEllipsis" />
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                    <TextBlock Text="No stashes" IsVisible="{Binding !HasStashes}" Opacity="0.4" />
                                </StackPanel>
                            </Flyout>
                        </Button.Flyout>
                    </Button>

                    <Button Content="⟳" Command="{Binding RefreshCommand}" ToolTip.Tip="Refresh" />
                </StackPanel>
            </Grid>

            <!-- Two file lists: unstaged | staged -->
            <Grid Grid.Row="1" ColumnDefinitions="*,12,*" Margin="0,14,0,0">

                <DockPanel Grid.Column="0">
                    <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,4">
                        <TextBlock Grid.Column="0" Text="Unstaged" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <Button Grid.Column="1" Content="Stage all" FontSize="11"
                                Command="{Binding StageAllCommand}" IsEnabled="{Binding !IsBusy}" />
                    </Grid>
                    <Border BorderBrush="#30808080" BorderThickness="1" CornerRadius="4">
                        <Panel>
                            <ListBox x:Name="UnstagedList"
                                     Background="Transparent"
                                     ItemsSource="{Binding UnstagedFiles}"
                                     SelectedItem="{Binding SelectedUnstagedFile}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate x:DataType="models:GitStatusEntry">
                                        <TextBlock Text="{Binding Path}" TextTrimming="CharacterEllipsis" />
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <TextBlock Text="No unstaged changes"
                                       IsVisible="{Binding !HasUnstagedFiles}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Opacity="0.35" IsHitTestVisible="False" />
                        </Panel>
                    </Border>
                </DockPanel>

                <DockPanel Grid.Column="2">
                    <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,4">
                        <TextBlock Grid.Column="0" Text="Staged" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <Button Grid.Column="1" Content="Unstage all" FontSize="11"
                                Command="{Binding UnstageAllCommand}" IsEnabled="{Binding !IsBusy}" />
                    </Grid>
                    <Border BorderBrush="#30808080" BorderThickness="1" CornerRadius="4">
                        <Panel>
                            <ListBox x:Name="StagedList"
                                     Background="Transparent"
                                     ItemsSource="{Binding StagedFiles}"
                                     SelectedItem="{Binding SelectedStagedFile}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate x:DataType="models:GitStatusEntry">
                                        <TextBlock Text="{Binding Path}" TextTrimming="CharacterEllipsis" />
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <TextBlock Text="Nothing staged"
                                       IsVisible="{Binding !HasStagedFiles}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Opacity="0.35" IsHitTestVisible="False" />
                        </Panel>
                    </Border>
                </DockPanel>
            </Grid>

            <!-- Commit -->
            <TextBox Grid.Row="2"
                     Margin="0,12,0,0"
                     MinHeight="56"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     PlaceholderText="Commit message"
                     Text="{Binding CommitMessage}"
                     IsEnabled="{Binding !IsBusy}" />

            <Grid Grid.Row="3" ColumnDefinitions="Auto,Auto,*" Margin="0,8,0,0">
                <Button Grid.Column="0" Classes="primary" Content="Commit" Command="{Binding CommitCommand}" IsEnabled="{Binding CanCommit}" />
                <TextBlock Grid.Column="1"
                           Text="✓ Working tree clean"
                           IsVisible="{Binding IsCleanTree}"
                           Margin="12,0,0,0"
                           VerticalAlignment="Center"
                           Foreground="#4CAF50"
                           Opacity="0.8" />
                <TextBlock Grid.Column="2"
                           Text="{Binding StatusText}"
                           Margin="12,0,0,0"
                           VerticalAlignment="Center"
                           Opacity="0.7"
                           TextTrimming="CharacterEllipsis" />
            </Grid>

            <TextBlock Grid.Row="4"
                       Margin="0,10,0,0"
                       Opacity="0.4"
                       FontSize="11"
                       Text="Double-click a file to stage/unstage · Esc back to the palette" />
        </Grid>
        </Panel>

    </DockPanel>

</Window>
