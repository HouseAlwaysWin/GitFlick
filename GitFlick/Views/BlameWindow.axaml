<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:GitFlick.ViewModels"
        xmlns:models="using:GitFlick.Models"
        xmlns:loc="using:GitFlick.Markup"
        x:Class="GitFlick.Views.BlameWindow"
        x:DataType="vm:BlameViewModel"
        Title="{Binding Title}"
        Icon="/Assets/gitflick.ico"
        Width="920" Height="620"
        MinWidth="480" MinHeight="280"
        WindowStartupLocation="CenterOwner">

    <DockPanel Margin="14">
        <TextBlock DockPanel.Dock="Top" Text="{Binding Title}" FontWeight="SemiBold"
                   TextTrimming="CharacterEllipsis" Margin="0,0,0,10" />

        <Border BorderBrush="#30808080" BorderThickness="1" CornerRadius="4" ClipToBounds="True">
            <Panel>
                <ListBox ItemsSource="{Binding Lines}" Background="Transparent"
                         FontFamily="Cascadia Mono,Consolas,Menlo,monospace" FontSize="12">
                    <ListBox.Styles>
                        <Style Selector="ListBoxItem">
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="MinHeight" Value="18" />
                        </Style>
                    </ListBox.Styles>
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="models:BlameLine">
                            <Grid ColumnDefinitions="76,132,84,*" Margin="6,1" ToolTip.Tip="{Binding Tooltip}">
                                <Grid.ContextFlyout>
                                    <MenuFlyout>
                                        <MenuItem Header="{loc:Tr History_Ctx_CopySha}" Click="OnCopyShaClick"
                                                  IsEnabled="{Binding !IsUncommitted}" />
                                    </MenuFlyout>
                                </Grid.ContextFlyout>
                                <TextBlock Grid.Column="0" Text="{Binding ShortSha}"
                                           Foreground="{DynamicResource FaintForeground}" />
                                <TextBlock Grid.Column="1" Text="{Binding Author}"
                                           IsVisible="{Binding !IsUncommitted}"
                                           Opacity="0.75" TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Column="1" Text="{loc:Tr Blame_Uncommitted}"
                                           IsVisible="{Binding IsUncommitted}"
                                           FontStyle="Italic" Opacity="0.55" TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Column="2" Text="{Binding WhenDisplay}" Opacity="0.55" />
                                <TextBlock Grid.Column="3" Text="{Binding Content}" TextTrimming="CharacterEllipsis" />
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <TextBlock Text="{loc:Tr Blame_Loading}" IsVisible="{Binding IsLoading}"
                           HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.5" />
                <TextBlock Text="{Binding Error}" IsVisible="{Binding HasError}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Opacity="0.65" TextWrapping="Wrap" MaxWidth="520" />
            </Panel>
        </Border>
    </DockPanel>
</Window>
