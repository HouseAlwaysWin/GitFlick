<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:GitFlick.ViewModels"
        xmlns:services="using:GitFlick.Services"
        xmlns:conv="using:GitFlick.Converters"
        xmlns:loc="using:GitFlick.Markup"
        x:Class="GitFlick.Views.CommandLogWindow"
        x:DataType="vm:WorkspaceViewModel"
        Title="{loc:Tr CmdLog_Title}"
        Icon="/Assets/gitflick.ico"
        Width="780" Height="500"
        MinWidth="420" MinHeight="220"
        WindowStartupLocation="CenterOwner">

    <DockPanel Margin="14">
        <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto,Auto,Auto" Margin="0,0,0,10">
            <TextBlock Grid.Column="0" Text="{loc:Tr CmdLog_Header}"
                       FontWeight="SemiBold" VerticalAlignment="Center" />
            <Button Grid.Column="1" Content="{loc:Tr CmdLog_Refresh}" Click="OnRefreshClick"
                    ToolTip.Tip="{loc:Tr CmdLog_Refresh_Tooltip}" />
            <Button Grid.Column="2" Content="{loc:Tr CmdLog_Copy}" Margin="6,0,0,0" Click="OnCopyClick"
                    IsEnabled="{Binding HasCommandLog}" />
            <Button Grid.Column="3" Content="{loc:Tr CmdLog_Clear}" Margin="6,0,0,0"
                    Command="{Binding ClearCommandLogCommand}" IsEnabled="{Binding HasCommandLog}" />
        </Grid>

        <!-- Master/detail: pick a command above, read exactly what git printed below — a push's
             "…master -> master" summary, or why something failed. The divider is draggable. -->
        <Grid RowDefinitions="2*,6,*">
            <Border Grid.Row="0" BorderBrush="#30808080" BorderThickness="1" CornerRadius="4" ClipToBounds="True">
                <Panel>
                    <ListBox x:Name="LogList" Background="Transparent" Padding="4"
                             ItemsSource="{Binding CommandLog}"
                             SelectedItem="{Binding SelectedCommandLogEntry}">
                        <ListBox.Styles>
                            <Style Selector="ListBoxItem">
                                <Setter Property="Padding" Value="4,2" />
                                <Setter Property="MinHeight" Value="0" />
                            </Style>
                        </ListBox.Styles>
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="services:GitCommandLogEntry">
                                <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto">
                                    <TextBlock Grid.Column="0" Text="{Binding Glyph}" Width="16" FontWeight="SemiBold"
                                               Foreground="{Binding Succeeded, Converter={StaticResource SuccessBrush}}" />
                                    <TextBlock Grid.Column="1" Text="{Binding TimeDisplay}" Opacity="0.45" FontSize="11"
                                               Margin="0,0,10,0" FontFamily="Cascadia Mono,Consolas,monospace"
                                               VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="2" Text="{Binding Command}"
                                               FontFamily="Cascadia Mono,Consolas,monospace" FontSize="12"
                                               TextTrimming="CharacterEllipsis" VerticalAlignment="Center"
                                               ToolTip.Tip="{Binding Command}" />
                                    <!-- A dot marks rows that actually have output to show. -->
                                    <TextBlock Grid.Column="3" Text="●" FontSize="9" Opacity="0.35"
                                               VerticalAlignment="Center" Margin="8,0,0,0"
                                               IsVisible="{Binding HasOutput}" />
                                    <TextBlock Grid.Column="4" Text="{Binding DurationDisplay}" Opacity="0.4" FontSize="11"
                                               Margin="10,0,0,0" VerticalAlignment="Center" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <TextBlock Text="{loc:Tr CmdLog_None}" IsVisible="{Binding !HasCommandLog}"
                               HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.4" />
                </Panel>
            </Border>

            <GridSplitter Grid.Row="1" Height="6" Background="Transparent"
                          ResizeDirection="Rows" ResizeBehavior="PreviousAndNext"
                          HorizontalAlignment="Stretch" />

            <Border Grid.Row="2" BorderBrush="#30808080" BorderThickness="1" CornerRadius="4" ClipToBounds="True">
                <Panel>
                    <TextBox IsReadOnly="True" Background="Transparent" BorderThickness="0"
                             IsVisible="{Binding HasSelectedCommandOutput}"
                             Text="{Binding SelectedCommandLogEntry.Output, Mode=OneWay}"
                             FontFamily="Cascadia Mono,Consolas,monospace" FontSize="12"
                             TextWrapping="NoWrap"
                             ScrollViewer.HorizontalScrollBarVisibility="Auto"
                             ScrollViewer.VerticalScrollBarVisibility="Auto" />
                    <TextBlock Text="{loc:Tr CmdLog_OutputHint}" IsVisible="{Binding !HasSelectedCommandOutput}"
                               HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.4"
                               TextWrapping="Wrap" MaxWidth="360" TextAlignment="Center" />
                </Panel>
            </Border>
        </Grid>
    </DockPanel>
</Window>
