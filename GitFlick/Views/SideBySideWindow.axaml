<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:services="using:GitFlick.Services"
        xmlns:conv="using:GitFlick.Converters"
        xmlns:loc="using:GitFlick.Markup"
        x:Class="GitFlick.Views.SideBySideWindow"
        Title="{loc:Tr SideBySide_Title}"
        Icon="/Assets/gitflick.ico"
        Width="1040" Height="720"
        MinWidth="620" MinHeight="360"
        WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <conv:DiffCellBrushConverter x:Key="DiffCellBrush" />
    </Window.Resources>

    <DockPanel Margin="12">
        <TextBlock DockPanel.Dock="Top" x:Name="HeaderText"
                   FontWeight="SemiBold" TextTrimming="CharacterEllipsis" Margin="2,0,0,8" />

        <Grid DockPanel.Dock="Top" ColumnDefinitions="*,1,*" Margin="0,0,0,6">
            <TextBlock Grid.Column="0" Text="{loc:Tr SideBySide_Old}" FontSize="11" Opacity="0.55" Margin="46,0,0,0" />
            <TextBlock Grid.Column="2" Text="{loc:Tr SideBySide_New}" FontSize="11" Opacity="0.55" Margin="46,0,0,0" />
        </Grid>

        <Border BorderBrush="#30808080" BorderThickness="1" CornerRadius="4" ClipToBounds="True">
            <ListBox x:Name="RowsList" Background="Transparent" BorderThickness="0" Padding="0">
                <ListBox.Styles>
                    <!-- Rows aren't selectable; strip padding and the selection/hover highlight so only
                         the per-cell diff tints show. -->
                    <Style Selector="ListBoxItem">
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="MinHeight" Value="0" />
                    </Style>
                    <Style Selector="ListBoxItem:selected /template/ ContentPresenter#PART_ContentPresenter">
                        <Setter Property="Background" Value="Transparent" />
                    </Style>
                    <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                        <Setter Property="Background" Value="Transparent" />
                    </Style>
                </ListBox.Styles>
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="services:DiffRow">
                        <Grid ColumnDefinitions="*,1,*">
                            <Grid Grid.Column="0" ColumnDefinitions="44,*"
                                  Background="{Binding LeftKind, Converter={StaticResource DiffCellBrush}}">
                                <TextBlock Grid.Column="0" Text="{Binding LeftLine}" Opacity="0.4" FontSize="11"
                                           TextAlignment="Right" Margin="0,0,8,0" VerticalAlignment="Top"
                                           FontFamily="Cascadia Mono,Consolas,monospace" />
                                <TextBlock Grid.Column="1" Text="{Binding LeftText}" TextWrapping="Wrap"
                                           FontFamily="Cascadia Mono,Consolas,monospace" FontSize="12" />
                            </Grid>
                            <Border Grid.Column="1" Background="{DynamicResource SeparatorBrush}" />
                            <Grid Grid.Column="2" ColumnDefinitions="44,*"
                                  Background="{Binding RightKind, Converter={StaticResource DiffCellBrush}}">
                                <TextBlock Grid.Column="0" Text="{Binding RightLine}" Opacity="0.4" FontSize="11"
                                           TextAlignment="Right" Margin="0,0,8,0" VerticalAlignment="Top"
                                           FontFamily="Cascadia Mono,Consolas,monospace" />
                                <TextBlock Grid.Column="1" Text="{Binding RightText}" TextWrapping="Wrap"
                                           FontFamily="Cascadia Mono,Consolas,monospace" FontSize="12" />
                            </Grid>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>
    </DockPanel>
</Window>
